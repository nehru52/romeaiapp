{
  "name": "@elizaos/plugin-host-shim",
  "version": "0.0.1",
  "description": "Cross-platform PluginHostShim contract. The view JavaScript shipped by a remote-mode plugin imports this and talks to its host through a uniform request / event surface; per-platform packages (-electrobun, -ios, -android, -web) provide the wiring.",
  "type": "module",
  "main": "./dist/index.js",
  "license": "MIT",
  "private": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc --noCheck -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src/",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src"
  },
  "dependencies": {
    "@elizaos/plugin-remote-manifest": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js",
      "default": "./dist/web.js"
    }
  }
}
