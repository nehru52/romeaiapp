{
  "name": "@elizaos/cloud-frontend",
  "private": true,
  "version": "2.0.3-beta.0",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite",
    "build": "bun --bun vite build && node scripts/verify-chunk-safety.mjs && bun run build:ssr && bun run prerender",
    "build:client": "bun --bun vite build && node scripts/verify-chunk-safety.mjs",
    "verify:chunks": "node scripts/verify-chunk-safety.mjs",
    "build:ssr": "bun --bun vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "prerender": "node scripts/prerender.mjs",
    "preview": "bun --bun vite preview --port 3000 --strictPort",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:live-auth": "node scripts/run-e2e.mjs tests/e2e/live-auth-backend.spec.ts",
    "test:e2e:update": "node scripts/run-e2e.mjs --update-snapshots",
    "audit:cloud": "bunx playwright install chromium && node scripts/run-e2e.mjs tests/e2e/aesthetic-audit.spec.ts --project=chromium-desktop --workers=1 && node -e \"const o=require('node:child_process'); const p=require('node:path'); const f=p.resolve('aesthetic-audit-output/contact-sheet.html'); const cmd=process.platform==='darwin'?'open':process.platform==='win32'?'start':'xdg-open'; o.spawn(cmd,[f],{stdio:'ignore',detached:true}).unref();\"",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "format": "bunx @biomejs/biome format --write src",
    "verify": "bun run lint && bun run typecheck && bun run build",
    "predev": "node ../shared/scripts/sync-to-public.mjs ./public --logos --ogembeds --background --background-videos",
    "prebuild": "node ../shared/scripts/sync-to-public.mjs ./public --logos --ogembeds --background --background-videos"
  },
  "dependencies": {
    "@elizaos/cloud-shared": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/poppins": "^5.2.7",
    "@mdx-js/rollup": "^3.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@react-three/fiber": "^9.6.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "1.98.4",
    "@simplewebauthn/browser": "^13.3.0",
    "@stwd/react": "^0.7.2",
    "@stwd/sdk": "^0.11.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.90.20",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@web3icons/react": "^4.1.17",
    "buffer": "^6.0.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.38.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.0.0",
    "react-router-dom": "^7.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-tweet": "^3.3.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.3.1",
    "three": "0.184.0",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "viem": "^2.48.8",
    "vite": "^8.0.10",
    "wagmi": "^3.6.15",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "browserify-sign": "^4.2.5",
    "bs58": "^6.0.0",
    "create-hash": "^1.2.0",
    "create-hmac": "^1.1.7",
    "elliptic": "^6.6.1",
    "hash-base": "^3.1.2",
    "jsdom": "^29.1.1",
    "secp256k1": "^5.0.1",
    "tweetnacl": "^1.0.3",
    "typescript": "^6.0.3",
    "sharp": "^0.34.5",
    "vitest": "^4.1.5"
  }
}
