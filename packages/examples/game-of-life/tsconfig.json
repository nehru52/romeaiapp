{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "rootDir": "../../..",
    "types": ["node"],
    "paths": {
      "@elizaos/plugin-inmemorydb": [
        "../../../plugins/plugin-inmemorydb/src/index.ts"
      ]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"],
  "extends": "../../../tsconfig.dist-paths.json"
}
