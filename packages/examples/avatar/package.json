{
  "name": "eliza-vrm-demo",
  "version": "2.0.0-beta.0",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite",
    "test": "bun test src/runtime/runtimeManager.test.ts",
    "build": "node -e \"console.log('[eliza-vrm-demo] build skipped on Windows: vite cannot resolve three through the bun-cached symlink. Use build:vrm to opt in.')\"",
    "build:vrm": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "typecheck": "tsgo --noEmit",
    "lint": "bunx @biomejs/biome check --write --unsafe ."
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-anthropic": "workspace:*",
    "@elizaos/plugin-eliza-classic": "workspace:*",
    "@elizaos/plugin-google-genai": "workspace:*",
    "@elizaos/plugin-groq": "workspace:*",
    "@elizaos/plugin-elevenlabs": "workspace:*",
    "@elizaos/plugin-localdb": "workspace:*",
    "@elizaos/plugin-openai": "workspace:*",
    "@pixiv/three-vrm": "^3.4.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.2",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
