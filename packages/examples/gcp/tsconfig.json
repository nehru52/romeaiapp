{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@elizaos/core": ["../../core/dist/index.d.ts"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
