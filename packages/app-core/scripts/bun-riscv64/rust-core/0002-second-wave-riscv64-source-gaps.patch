@@ -48,7 +48,24 @@ bitflags::bitflags! {
     }
 }
 
-#[cfg(not(any(target_arch = "x86_64", target_arch = "aarch64")))]
+// riscv64: `bun_cpu_features()` (CPUFeatures.cpp, CPU(RISCV64)) returns 0 — no
+// feature bits are surfaced in crash diagnostics — so only the NONE sentinel is
+// modeled. Keeps `get()`'s padding assert valid (raw == 0).
+#[cfg(target_arch = "riscv64")]
+bitflags::bitflags! {
+    #[repr(transparent)]
+    #[derive(Copy, Clone)]
+    pub struct Flags: u8 {
+        const NONE = 1 << 0;
+        // bits 1..=7 = padding
+    }
+}
+
+#[cfg(not(any(
+    target_arch = "x86_64",
+    target_arch = "aarch64",
+    target_arch = "riscv64"
+)))]
 compile_error!("CPUFeatures: unsupported target architecture");
 
