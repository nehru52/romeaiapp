diff --git a/src/perf/hw_timer.rs b/src/perf/hw_timer.rs
index 736ff3f..a7820b8 100644
--- a/src/perf/hw_timer.rs
+++ b/src/perf/hw_timer.rs
@@ -57,7 +57,26 @@ pub fn read_counter() -> u64 {
         }
         return ((hi as u64) << 32) | (lo as u64);
     }
-    #[cfg(not(any(target_arch = "aarch64", target_arch = "x86_64")))]
+    #[cfg(target_arch = "riscv64")]
+    {
+        let ret: u64;
+        // SAFETY: the `time` CSR (rdtime) is a side-effect-free, userspace-readable
+        // fixed-frequency counter on riscv64 Linux — the direct analog of aarch64's
+        // CNTVCT_EL0. (`rdcycle` is privileged on many kernels; `time` is not.)
+        unsafe {
+            core::arch::asm!(
+                "rdtime {ret}",
+                ret = out(reg) ret,
+                options(nomem, nostack, preserves_flags),
+            );
+        }
+        return ret;
+    }
+    #[cfg(not(any(
+        target_arch = "aarch64",
+        target_arch = "x86_64",
+        target_arch = "riscv64"
+    )))]
     compile_error!("hw_timer::read_counter: unsupported architecture");
 }
 
