            android:action="android.intent.action.VIEW"
            android:targetPackage="ai.elizaos.app"
            android:targetClass="ai.elizaos.app.MainActivity"
            android:data="elizaos://voice?source=android-static-shortcut" />
        <capability-binding android:key="actions.intent.OPEN_APP_FEATURE">
            <parameter-binding
                android:key="feature"
                android:value="@array/app_action_voice_features" />
        </capability-binding>
    </shortcut>

    <shortcut
        android:shortcutId="eliza_app_action_daily_brief"
        android:shortcutShortLabel="@string/app_action_daily_brief_short"
        android:shortcutLongLabel="@string/app_action_daily_brief_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="ai.elizaos.app"
            android:targetClass="ai.elizaos.app.MainActivity"
            android:data="elizaos://lifeops/daily-brief?source=android-static-shortcut" />
        <capability-binding android:key="actions.intent.OPEN_APP_FEATURE">
            <parameter-binding
                android:key="feature"
                android:value="@array/app_action_daily_brief_features" />
        </capability-binding>
    </shortcut>

    <shortcut
        android:shortcutId="eliza_app_action_new_task"
        android:shortcutShortLabel="@string/app_action_new_task_short"
        android:shortcutLongLabel="@string/app_action_new_task_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="ai.elizaos.app"
            android:targetClass="ai.elizaos.app.MainActivity"
            android:data="elizaos://lifeops/task/new?source=android-static-shortcut" />
        <capability-binding android:key="actions.intent.OPEN_APP_FEATURE">
            <parameter-binding
                android:key="feature"
                android:value="@array/app_action_new_task_features" />
        </capability-binding>
    </shortcut>

    <shortcut
        android:shortcutId="eliza_app_action_tasks"
        android:shortcutShortLabel="@string/app_action_tasks_short"
        android:shortcutLongLabel="@string/app_action_tasks_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="ai.elizaos.app"
            android:targetClass="ai.elizaos.app.MainActivity"
