{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Electrobun OTA update channel manifest",
  "type": "object",
  "required": ["channel", "version", "updatedAt", "platforms"],
  "properties": {
    "channel": { "type": "string", "enum": ["stable", "canary"] },
    "version": { "type": "string" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "platforms": {
      "type": "object",
      "properties": {
        "macos-arm64": { "type": "string", "format": "uri" },
        "macos-x64": { "type": "string", "format": "uri" },
        "windows-x64": { "type": "string", "format": "uri" },
        "linux-x64": { "type": "string", "format": "uri" },
        "linux-arm64": { "type": "string", "format": "uri" },
        "linux-riscv64": { "type": "string", "format": "uri" }
      }
    }
  }
}
