{
  "id": "eliza.runtime",
  "name": "Eliza Runtime",
  "version": "0.1.0",
  "description": "Runtime Remote that supervises the local elizaOS runtime.",
  "mode": "background",
  "permissions": {
    "host": {
      "storage": true,
      "manage-remote-plugins": true
    },
    "bun": {
      "read": true,
      "write": true,
      "env": true,
      "run": true,
      "worker": true
    },
    "isolation": "shared-worker"
  },
  "view": {
    "relativePath": "src/web/index.html",
    "title": "Eliza Runtime Remote",
    "width": 720,
    "height": 520
  },
  "worker": {
    "relativePath": "src/bun/worker.ts"
  }
}
