{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": "../../",
    "rewriteRelativeImportExtensions": true,
    "stripInternal": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@elizaos/app-core": ["./src/index.ts"],
      "@elizaos/agent": ["../agent/dist/packages/agent/src/index.d.ts"],
      "@elizaos/agent/*": ["../agent/dist/packages/agent/src/*"],
      "@elizaos/core": ["../core/dist/index.node.d.ts"],
      "@elizaos/shared": ["../shared/dist/index.d.ts"],
      "@elizaos/ui": ["../ui/dist/index.d.ts"],
      "@elizaos/vault": ["../vault/dist/index.d.ts"],
      "@elizaos/plugin-browser": [
        "../../plugins/plugin-browser/dist/index.d.ts"
      ],
      "@elizaos/plugin-elizacloud": [
        "../../plugins/plugin-elizacloud/dist/index.node.d.ts"
      ],
      "@elizaos/plugin-sql": [
        "../../plugins/plugin-sql/src/dist/index.node.d.ts"
      ],
      "@elizaos/plugin-wechat": ["../../plugins/plugin-wechat/dist/index.d.ts"],
      "@elizaos/capacitor-*": ["../native-plugins/*/dist/index.d.ts"],
      "@elizaos/native-activity-tracker": [
        "../native-plugins/activity-tracker/dist/index.d.ts"
      ],
      "drizzle-orm": ["../../plugins/plugin-sql/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../plugins/plugin-sql/node_modules/drizzle-orm/*"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": [
        "./node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "lucide-react": ["./node_modules/lucide-react"]
    }
  },
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": ["src", "../agent/src/external-modules.d.ts"]
}
