# Pinned versions for native dependencies cross-built for iOS.
# Format: <name>=<git_sha_or_tag>
#
# Update these when bumping a dep. Each entry should match the version Bun
# upstream pins for desktop, unless we have a specific reason to diverge.

boringssl=excluded-from-ios-build
c-ares=excluded-from-ios-build
lol-html=excluded-from-ios-build
mimalloc=excluded-from-ios-build
zstd=excluded-from-ios-build
brotli=excluded-from-ios-build

# llama.cpp pin for on-device inference. Tracks the elizaOS fork at
# https://github.com/elizaOS/llama.cpp (branch `main`), not upstream
# ggml-org. The fork carries the elizaOS kernels (Q4_POLAR / QJL1_256 /
# TBQ4_0 / TBQ3_0 GGML types + Metal/Vulkan/CUDA kernels) and MTP
# spec-decode, which on-device inference relies on. Bump deliberately,
# not on every commit; pick a commit SHA that's known to build a green
# llama-server on macOS arm64.
#
# Current pin ce85787c8 (2026-05-13): main HEAD after the
# omnivoice-build-flag + openvino-backend-import cleanup. CPU build
# verified on macOS arm64; iOS Metal build inherits from the same source
# tree.
llama.cpp=ce85787c8

# sqlite-vec pin — vector storage + KNN extension that replaces pgvector
# for the on-device SQLite backend (PGlite cannot run in JSContext on
# iOS 16.4+ because WebAssembly is gated off). Track upstream release tags
# from https://github.com/asg017/sqlite-vec/releases. v0.1.6 is the first
# release that builds cleanly with the iOS toolchain (no AVX assumptions
# in the default config; NEON path tested on iPhone 12+).
sqlite-vec=v0.1.6

# Excluded from iOS build entirely:
# tinycc — runtime executable-page allocation forbidden on iOS
# libuv — Bun uses kqueue directly on Darwin (incl. iOS)
