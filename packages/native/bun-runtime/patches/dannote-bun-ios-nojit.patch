+static void sortStackTraceIndicesByTimestamp(const StackTraces& stackTraces, WTF::Vector<size_t>& sortedIndices)
+{
+    for (size_t i = 1; i < sortedIndices.size(); ++i) {
+        size_t key = sortedIndices[i];
+        double keyTimestamp = stackTraces[key].timestamp.secondsSinceEpoch().value();
+        size_t j = i;
