{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "moduleDetection": "force",
    "outDir": "./dist",
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@feed/shared": ["../../packages/shared/dist/index.d.ts"],
      "@feed/shared/*": ["../../packages/shared/dist/*"],
      "@feed/db": ["../../packages/db/dist/index.d.ts"],
      "@feed/db/*": ["../../packages/db/dist/*"],
      "@feed/engine": ["../../packages/engine/dist/index.d.ts"],
      "@feed/engine/*": ["../../packages/engine/dist/*"],
      "@feed/api": ["../../packages/api/dist/index.d.ts"],
      "@feed/api/*": ["../../packages/api/dist/*"],
      "@feed/contracts": ["../../packages/contracts/src/index.ts"],
      "@feed/contracts/*": ["../../packages/contracts/*"],
      "@feed/agents": ["../../packages/agents/dist/index.d.ts"],
      "@feed/agents/*": ["../../packages/agents/dist/*"],
      "@feed/a2a": ["../../packages/a2a/dist/index.d.ts"],
      "@feed/a2a/*": ["../../packages/a2a/dist/*"],
      "@feed/mcp": ["../../packages/mcp/dist/index.d.ts"],
      "@feed/training": ["../../packages/agents/dist/training/index.d.ts"],
      "@feed/training/*": ["../../packages/agents/dist/training/*"],
      "@feed/testing": ["./src/types/feed-testing.d.ts"],
      "@feed/core": ["../../packages/core/dist/markets/index.d.ts"],
      "@feed/core/markets/*": ["../../packages/core/dist/markets/*"],
      "@feed/pack-default": ["../../packages/pack-default/dist/index.d.ts"],
      "@feed/pack-default/*": ["../../packages/pack-default/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/__tests__/**/*"]
}
