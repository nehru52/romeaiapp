{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "baseUrl": ".",
    "types": ["node", "bun-types"],
    "paths": {
      "@feed/shared": ["../shared/src/index.ts"],
      "@feed/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__/**/*"],
  "references": [{ "path": "../shared" }]
}
