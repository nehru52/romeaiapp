{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": false,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strict": false,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "next": ["../../node_modules/next"],
      "next/*": ["../../node_modules/next/*"],
      "@/shared/constants": ["../../apps/web/src/shared/constants.ts"],
      "@/shared/types": ["../../apps/web/src/shared/types.ts"],
      "@/shared/utils": ["../../apps/web/src/shared/utils.ts"],
      "@/components/*": ["../../apps/web/src/components/*"],
      "@/lib/*": ["../../apps/web/src/lib/*"],
      "@/hooks/*": ["../../apps/web/src/hooks/*"],
      "@/stores/*": ["../../apps/web/src/stores/*"],
      "@/app/*": ["../../apps/web/src/app/*"],
      "@/*": ["../../apps/web/src/*"],
      "@feed/core": ["../core/markets/index.ts"],
      "@feed/core/*": ["../core/*"],
      "@feed/shared": ["../shared/src/index.ts"],
      "@feed/shared/*": ["../shared/src/*"],
      "@feed/db": ["../db/src/index.ts"],
      "@feed/db/*": ["../db/src/*"],
      "@feed/engine": ["../engine/src/index.ts"],
      "@feed/engine/*": ["../engine/src/*"],
      "@feed/api": ["../api/src/index.ts"],
      "@feed/api/*": ["../api/src/*"],
      "@feed/agents": ["../agents/src/index.ts"],
      "@feed/agents/*": ["../agents/src/*"],
      "@feed/a2a": ["../a2a/src/index.ts"],
      "@feed/a2a/*": ["../a2a/src/*"],
      "@feed/mcp": ["../mcp/src/index.ts"],
      "@feed/web/*": ["../../apps/web/*"],
      "@feed/testing": ["./src/index.ts"],
      "@feed/testing/*": ["./*"]
    }
  },
  "include": [
    "unit/**/*",
    "integration/**/*",
    "performance/**/*",
    "e2e/**/*",
    "load-test/**/*",
    "simulation/**/*",
    "helpers/**/*",
    "types/**/*",
    "shared/**/*",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "manual/**/*",
    "dist",
    "verification/**/*",
    "integration/admin-agents-reputation.integration.test.ts",
    "integration/agent-autonomous-tick.integration.test.ts",
    "integration/markets-tick.integration.test.ts"
  ],
  "references": [
    { "path": "../core" },
    { "path": "../shared" },
    { "path": "../db" },
    { "path": "../engine" },
    { "path": "../api" },
    { "path": "../agents" },
    { "path": "../a2a" },
    { "path": "../mcp" }
  ]
}
