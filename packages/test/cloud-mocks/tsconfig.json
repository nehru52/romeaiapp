{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "declaration": false,
    "types": ["node", "bun-types"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true
  },
  "include": ["./src/**/*.ts", "./bin/**/*.ts", "./test/**/*.ts"],
  "exclude": ["node_modules"]
}
