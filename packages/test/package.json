{
  "name": "@elizaos/test-harness",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Zero-cost end-to-end test substrate: the deterministic mock-LLM proxy, a one-import withMockLlmRuntime() helper, and a shared negative-response fixture pack.",
  "main": "./harness/index.ts",
  "exports": {
    ".": "./harness/index.ts",
    "./llm-proxy": "./mocks/helpers/llm-proxy-plugin.ts",
    "./action-route-fixtures": "./harness/action-route-fixtures.ts",
    "./negative-fixtures": "./harness/negative-fixtures.ts"
  },
  "scripts": {
    "test": "vitest run --config harness/vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*"
  },
  "devDependencies": {
    "vitest": "*"
  }
}
