{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "./src",
    "paths": {
      "@elizaos/core": ["../core/dist/index.node.d.ts"],
      "@elizaos/core/testing": ["../core/dist/testing/index.d.ts"],
      "@elizaos/core/*": ["../core/dist/*"],
      "@elizaos/capacitor-appblocker": [
        "../native-plugins/appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../native-plugins/mobile-signals/src/index.ts"
      ]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/__tests__/**/*",
    "src/executor.test.ts",
    "src/seeds.ts"
  ]
}
