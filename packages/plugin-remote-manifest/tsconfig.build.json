{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@elizaos/security": ["../security/dist/index.d.ts"],
      "@elizaos/security/*": ["../security/dist/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
