{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "../../",
    "rewriteRelativeImportExtensions": true,
    "stripInternal": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@elizaos/ui": ["./src/index.ts"],
      "@elizaos/core": ["../core/dist/index.d.ts"],
      "@elizaos/shared": ["../shared/dist/index.d.ts"],
      "@elizaos/agent": ["../agent/dist/packages/agent/src/index.d.ts"],
      "@elizaos/plugin-coding-tools": [
        "../../plugins/plugin-coding-tools/dist/index.d.ts"
      ],
      "@elizaos/plugin-wallet-ui": [
        "../../plugins/plugin-wallet-ui/src/index.ts"
      ],
      "@elizaos/plugin-browser": ["../../plugins/plugin-browser/src/index.ts"],
      "@elizaos/plugin-health/screen-time/mobile-signal-setup": [
        "../../plugins/plugin-health/src/screen-time/mobile-signal-setup.ts"
      ],
      "@elizaos/plugin-video": ["../../plugins/plugin-video/dist/index.d.ts"],
      "@elizaos/capacitor-*": ["../native-plugins/*/dist/index.d.ts"],
      "@elizaos/native-activity-tracker": [
        "../native-plugins/activity-tracker/dist/index.d.ts"
      ]
    }
  },
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": ["src", "../agent/src/external-modules.d.ts"]
}
