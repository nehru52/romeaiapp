{
  "name": "__APP_PACKAGE_NAME__",
  "version": "2.0.0-beta.0",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite",
    "preview": "bun --bun vite preview",
    "design-review": "node --import tsx test/design-review/run-design-review.ts",
    "lint": "bunx @biomejs/biome check src test scripts vite.config.ts vitest.config.ts vitest.e2e.config.ts playwright.ui-smoke.config.ts playwright.ui-packaged.config.ts playwright.electrobun.packaged.config.ts playwright.web-views.config.ts package.json capacitor.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:ui": "vitest run --config vitest.config.ts test/app/command-palette.test.tsx test/app/chat-view.test.tsx test/app/conversations-sidebar.test.tsx test/app/events.test.ts test/app/command-registry.test.ts test/app/shell-overlays.test.tsx test/app/shortcuts-overlay.test.tsx test/app/confirm-modal.test.tsx",
    "test:e2e": "node scripts/run-ui-playwright.mjs --config playwright.ui-smoke.config.ts",
    "test:e2e:settings-chat": "node scripts/run-ui-playwright.mjs --config playwright.ui-smoke.config.ts test/ui-smoke/settings-chat-companion.spec.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "plugin:build": "bun scripts/plugin-build.mjs",
    "build": "bun scripts/build.mjs",
    "build:ios": "node ../../../../../scripts/run-eliza-app-core-script.mjs run-mobile-build.mjs ios",
    "build:android": "node ../../../../../scripts/run-eliza-app-core-script.mjs run-mobile-build.mjs android",
    "ios": "node ../../../../../scripts/run-eliza-app-core-script.mjs run-mobile-build.mjs ios && capacitor open ios",
    "android": "node ../../../../../scripts/run-eliza-app-core-script.mjs run-mobile-build.mjs android && capacitor open android",
    "cap:sync": "capacitor sync",
    "cap:sync:ios": "capacitor sync ios",
    "cap:sync:android": "capacitor sync android",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android",
    "build:web": "bun --bun vite build"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@elizaos/app-core": "latest",
    "@elizaos/core": "latest",
    "@elizaos/ui": "latest",
    "@elizaos/shared": "latest",
    "@pixiv/three-vrm": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.2.1",
    "jsdom": "^29.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.0.0"
  }
}
