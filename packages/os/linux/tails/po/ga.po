"The available incremental upgrade requires {space_needed} of free space on "
"Tails system partition,  but only {free_space} is available."
msgstr ""
"Teastaíonn {space_needed} de spás saor in aisce ar dheighilt chórais Tails "
"leis an uasghrádú incriminteach atá ar fáil, ach níl ach {free_space} ar "
"fáil."

#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:462
#, perl-brace-format
msgid ""
"The available incremental upgrade requires {memory_needed} of free memory, "
"but only {free_memory} is available."
