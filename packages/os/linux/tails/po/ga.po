msgstr "Níl aon mhíniú ar fáil ar chúis '{reason}'."

#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:408
msgid "The system is up-to-date"
msgstr "Tá an córas cothrom le dáta"

#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:411
msgid ""
"You are currently running the latest version. There is no upgrade "
"available.\n"
msgstr ""
"Tá an leagan is déanaí á rith agat faoi láthair. Níl aon uasghrádú ar fáil.\n"

#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:414
