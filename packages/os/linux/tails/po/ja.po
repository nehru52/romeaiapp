msgstr "ブリッジなしで Tor に接続できませんでした。"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2250
msgid "This local network is blocking access to Tor."
msgstr "このローカルネットワークは Tor へのアクセスをブロックしています。"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2282
msgid "Connecting to Tor…"
msgstr "Tor に接続中…"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2387
msgid "Start Tor Browser"
msgstr "Tor Browser を起動"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2446
msgid "Configure a Local Proxy"
msgstr "ローカルプロキシを構成"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2472
msgid "Proxy Type"
msgstr "プロキシの種類"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2489
msgid "No proxy"
msgstr "プロキシなし"

