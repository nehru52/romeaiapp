msgstr "SOCKS 4"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2491
msgid "SOCKS 5"
msgstr "SOCKS 5"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2492
msgid "HTTP / HTTPS"
msgstr "HTTP / HTTPS"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2511
msgid "Address"
msgstr "アドレス"

#: ../config/chroot_local-includes/usr/share/tails/tca/main.ui.in:2528
