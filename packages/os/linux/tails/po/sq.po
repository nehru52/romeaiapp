#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:365
msgid "your device was not created using a USB image or Tails Cloner"
msgstr "pajisja s’qe krijuar duke përdorur një pamje USB ose Klonuesin Tails"

#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:370
