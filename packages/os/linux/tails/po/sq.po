msgstr "Gabim teksa shkarkohej kyçi i nënshkrimit"

#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:342
msgid "Error while checking for upgrades"
msgstr "Gabim teksa kontrollohej për përmirësime"

#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:344
msgid ""
"<b>Could not determine whether an upgrade is available from our website.</"
"b>\n"
"\n"
"Check your network connection and restart Tails.\n"
"\n"
"If the problem persists, try doing a manual upgrade."
msgstr ""
"<b>S’përcaktohet dot nëse ka apo jo një përmirësim nga sajti ynë.</b>\n"
"\n"
"Kontrolloni lidhjen tuaj në rrjet dhe rinisni Tails.\n"
"\n"
"Nëse problemi vazhdon, provoni të bëni përmirësim, dorazi."

#: config/chroot_local-includes/usr/src/iuk/lib/Tails/IUK/Frontend.pm:359
