"ein."

#. type: Bullet: '   * '
msgid "Select **Create**."
msgstr ""

#. type: Plain text
#, no-wrap
msgid ""
"   <div class=\"caution\">\n"
"   <p>It is impossible to recover your passphrase if you forget it!</p>\n"
