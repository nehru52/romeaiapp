#~ msgstr "**Courrier électronique**"

#~ msgid "**Telegram**"
#~ msgstr "**Telegram**"

#, no-wrap
#~ msgid ""
#~ "  You can send the message `/bridges` to\n"
#~ "  [@GetBridgesBot](https://t.me/GetBridgesBot) on *Telegram*.\n"
#~ msgstr ""
#~ "  Vous pouvez envoyer le message `/bridges` à\n"
#~ "  [@GetBridgesBot](https://t.me/GetBridgesBot) sur *Telegram*.\n"

