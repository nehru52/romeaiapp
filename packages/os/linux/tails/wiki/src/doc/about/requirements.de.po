#. type: Bullet: '- '
#, fuzzy
#| msgid "Newer Mac computers with an Apple processor (M1 or M2)"
msgid "Mac computers with an Apple processor (M1, M2, and so on)"
msgstr "Neuere Mac-Computer mit einem Apple-Prozessor (M1 oder M2)"

#. type: Bullet: '- '
msgid "Smartphones or tablets"
msgstr "Smartphones oder Tablets"

#. type: Bullet: '- '
msgid "Raspberry Pi"
