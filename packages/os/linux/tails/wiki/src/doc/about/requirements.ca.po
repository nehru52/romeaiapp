#. type: Bullet: '- '
#, fuzzy
#| msgid "Newer Mac computers with an Apple processor (M1, M2, and so on)"
msgid "Mac computers with an Apple processor (M1, M2, and so on)"
msgstr "Ordinadors Mac més nous amb un processador Apple (M1, M2, etc.)"

#. type: Bullet: '- '
msgid "Smartphones or tablets"
msgstr "Telèfons intel·ligents o tauletes"

#. type: Bullet: '- '
