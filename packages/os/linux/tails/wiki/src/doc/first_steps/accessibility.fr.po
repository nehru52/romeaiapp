#, no-wrap
msgid ""
"<p>The screen keyboard doesn't work in <i>Kleopatra</i> and <i>Electrum</i>.\n"
"([[!tails_ticket 19695]])</p>\n"
msgstr ""
"<p>Le clavier visuel ne fonctionne pas dans <i>Kleopatra</i> et "
"<i>Electrum</i>.\n"
"([[!tails_ticket 19695]])</p>\n"

#. type: Plain text
#, no-wrap
