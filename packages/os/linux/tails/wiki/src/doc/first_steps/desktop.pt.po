msgid "<h2 id=\"tor-status\">Tor status and circuits</h2>\n"
msgstr "<h2 id=\"tor-status\">Estado e circuitos do Tor</h2>\n"

#. type: Plain text
msgid ""
"The Tor status icon ([[!img lib/symbolic/tor-disconnected.png alt=\"Tor "
"status menu\" link=\"no\" class=\"symbolic\"]] or [[!img lib/symbolic/tor-"
"connected.png alt=\"Tor status menu\" link=\"no\" class=\"symbolic\"]]) "
"provides a shortcut to *Onion Circuits*, which allows you to manage the Tor "
"circuits being used by Tails."
msgstr ""
"O ícone de estado do Tor ([[!img lib/symbolic/tor-disconnected.png "
"alt=\"Menu de estado do Tor\" link=\"no\" class=\"symbolic\"]] or [[!img lib/"
"symbolic/tor-connected.png alt=\"Menu de estado do Tor\" link=\"no\" "
"class=\"symbolic\"]]) provê um atalho para *Circuitos onion*, que permite "
"que você gerencie os circuitos da rede Tor usados pelo Tails."

