#| msgid "[[!meta title=\"Resetting a USB stick using Windows\"]]\n"
msgid "[[!meta title=\"Uninstalling Tails using Windows\"]]\n"
msgstr "[[!meta title=\"Einen USB-Stick unter Windows zurücksetzen\"]]\n"

#. type: Plain text
#, fuzzy, no-wrap
#| msgid "[[!inline pages=\"doc/reset.intro\" raw=\"yes\" sort=\"age\"]]\n"
msgid "[[!inline pages=\"doc/first_steps/uninstall.intro\" raw=\"yes\" sort=\"age\"]]\n"
msgstr "[[!inline pages=\"doc/reset.intro.de\" raw=\"yes\" sort=\"age\"]]\n"

#. type: Plain text
#, no-wrap
msgid "[[!toc startlevel=2]]\n"
msgstr ""

#. type: Title -
#, fuzzy, no-wrap
#| msgid "Erase Tails from the USB stick"
msgid "Erasing Tails from the USB stick"
msgstr "Tails vom USB-Stick löschen"

#. type: Plain text
msgid "First, erase Tails from the USB stick:"
msgstr "Zuerst löschen Sie Tails vom USB-Stick:"

#. type: Bullet: '1. '
msgid "Start on Windows."
msgstr ""

#. type: Bullet: '1. '
#, fuzzy
#| msgid ""
#| "Open the **Start** ([[!img lib/start.png class=\"symbolic\" link=\"no\" "
#| "alt=\"\"]]) menu."
msgid ""
"Select the **Start** [[!img lib/start.png alt=\"\" class=\"symbolic\" "
"link=\"no\"]] button and open the *Settings* app."
msgstr ""
"Öffnen Sie das **Start** ([[!img lib/start.png class=\"symbolic\" "
"link=\"no\" alt=\"\"]])-Menü."

#. type: Bullet: '1. '
msgid ""
"In the *Settings* app, choose **System&nbsp;▸ Storage&nbsp;▸ Advanced "
"storage settings&nbsp;▸ Disk & volumes**."
msgstr ""

#. type: Bullet: '1. '
#, fuzzy
#| msgid "Plug in the USB stick that you want to reset."
msgid "Plug in the Tails USB stick that you want to uninstall."
msgstr "Schließen Sie den USB-Stick, den Sie zurücksetzen möchten, an."

#. type: Plain text
#, no-wrap
msgid "   [[!img disks.png class=\"screenshot\" alt=\"\"]]\n"
msgstr "   [[!img disks.png class=\"screenshot\" alt=\"\"]]\n"

#. type: Bullet: '1. '
msgid "Identify the USB stick in the list of disks."
msgstr ""

#. type: Bullet: '1. '
msgid "Identify the volume called **TAILS**, which has a FAT32 file system."
msgstr ""

#. type: Plain text
#, fuzzy, no-wrap
#| msgid "Execute the <span class=\"command\">create partition primary</span> command to create a new primary partition on the USB stick."
msgid "   This volume corresponds to the Tails system partition on the USB stick.\n"
msgstr "Führen Sie den Befehl <span class=\"command\">create partition primary</span> aus, um eine neue primäre Partition auf dem USB-Stick zu erstellen."

#. type: Bullet: '   1. '
msgid "Select the **Properties** button corresponding to the **TAILS** volume."
msgstr ""

#. type: Bullet: '   1. '
msgid "In the properties of the **TAILS** volume, select **Delete**."
msgstr ""

#. type: Plain text
#, no-wrap
msgid "      Windows gives no feedback after deletion.\n"
msgstr ""

#. type: Bullet: '1. '
msgid "Select **Disks & volumes** to go back to the list of volumes."
msgstr ""

#. type: Bullet: '1. '
msgid ""
"If there is a [[Persistent Storage|doc/persistent_storage]] on the USB "
"stick, a volume called **(No label)** also appears on the USB stick."
msgstr ""

#. type: Plain text
#, no-wrap
msgid "   This volume corresponds to the Tails Persistent Storage on the USB stick.\n"
msgstr ""

#. type: Bullet: '   1. '
msgid ""
"Select the **Properties** button corresponding to the **(No label)** volume."
msgstr ""

#. type: Bullet: '   1. '
msgid "In the properties of the **(No label)** volume, select **Delete**."
msgstr ""

#. type: Bullet: '1. '
msgid "The USB stick now has no volumes and is entirely unallocated."
msgstr ""

#. type: Title -
#, fuzzy, no-wrap
#| msgid "Execute the <span class=\"command\">convert mbr</span> command to create a new partition table on the USB stick."
msgid "Creating a new partition on the USB stick"
msgstr "Führen Sie den Befehl <span class=\"command\">convert mbr</span> aus, um eine neue Partitionstabelle auf dem USB-Stick zu erstellen."

#. type: Plain text
msgid "Then, create a new partition on the USB stick:"
msgstr ""

#. type: Bullet: '1. '
msgid "Select the **Properties** button corresponding to the USB stick."
msgstr ""

#. type: Bullet: '1. '
msgid "In the properties of the USB stick, select **Convert to MBR**."
msgstr ""

#. type: Bullet: '1. '
msgid ""
"Select the **Create Volume** button for the USB stick and choose **Create "
"Simple Volume**."
msgstr ""

#. type: Bullet: '1. '
msgid ""
"In the **New Volume** dialog, enter a label of your choice and select "
"**Format**."
msgstr ""

#. type: Bullet: '1. '
msgid "Unplug the USB stick."
msgstr "Ziehen Sie den USB-Stick ab."

#. type: Bullet: '1. '
msgid "Close the *Settings* app."
msgstr ""

#. type: Bullet: '1. '
#, fuzzy
#| msgid ""
#| "Open the **Start** ([[!img lib/start.png class=\"symbolic\" link=\"no\" "
#| "alt=\"\"]]) menu."
msgid ""
"Select the **Start** [[!img lib/start.png alt=\"\" class=\"symbolic\" "
"link=\"no\"]] button and open the *File Explorer* app."
msgstr ""
"Öffnen Sie das **Start** ([[!img lib/start.png class=\"symbolic\" "
"link=\"no\" alt=\"\"]])-Menü."

#. type: Bullet: '1. '
#, fuzzy
#| msgid "Unplug the USB stick."
msgid "Plug back the USB stick."
msgstr "Ziehen Sie den USB-Stick ab."

#. type: Plain text
#, no-wrap
msgid "   Your new volume appears in the left sidebar of the *File Explorer*.\n"
msgstr ""

#, no-wrap
#~ msgid "<div class=\"caution\">\n"
#~ msgstr "<div class=\"caution\">\n"

#, no-wrap
#~ msgid "<p><b>You might overwrite any hard disk on the computer.</b></p>\n"
#~ msgstr "<p><b>Sie könnten jegliche Festplatten des Computers überschreiben.</b></p>\n"

#, no-wrap
#~ msgid "<p>If at some point you are not sure about which device to choose, stop proceeding.</p>\n"
#~ msgstr "<p>Falls Sie sich an irgendeinem Punkt unsicher darüber sind, welches Medium Sie wählen sollen, brechen Sie den Vorgang ab.</p>\n"

#, no-wrap
#~ msgid "</div>\n"
#~ msgstr "</div>\n"

#~ msgid "Make sure that the USB stick that you want to reset is unplugged."
#~ msgstr ""
#~ "Stellen Sie sicher, dass der USB-Stick, den Sie zurücksetzen möchten, "
#~ "nicht angeschlossen ist."

#~ msgid "Choose **Windows System**&nbsp;▸ **Command Prompt**."
#~ msgstr "Wählen Sie **Windows-System**&nbsp;▸ **Eingabeaufforderung**."

#~ msgid "Execute the following command to start the *Diskpart* utility."
#~ msgstr ""
#~ "Führen Sie den folgenden Befehl aus, um das *Diskpart*-Dienstprogramm zu "
#~ "starten."

#, no-wrap
#~ msgid "   <p class=\"command-windows\">diskpart</p>\n"
#~ msgstr "   <p class=\"command-windows\">diskpart</p>\n"

#~ msgid ""
#~ "Execute the following command to obtain information about the disks in "
#~ "the computer."
#~ msgstr ""
#~ "Führen Sie den folgenden Befehl aus, um Informationen über die "
#~ "Festplatten im Computer zu erhalten."

#, no-wrap
#~ msgid "   <p class=\"command-windows\">list disk</p>\n"
#~ msgstr "   <p class=\"command-windows\">list disk</p>\n"

#, no-wrap
#~ msgid "   For example:\n"
#~ msgstr "   Zum Beispiel:\n"

#, no-wrap
#~ msgid "       Diskpart> list disk\n"
#~ msgstr "       Diskpart> list disk\n"

#, no-wrap
#~ msgid ""
#~ "         Disk ###  Status      Size     Free     Dyn  Gpt\n"
#~ "         --------  ----------  -------  -------  ---  ---\n"
#~ "         Disk 0    Online        80 GB      0 B\n"
#~ msgstr ""
#~ "         Datenträger ###  Status      Größe     Frei     Dyn  GPT\n"
#~ "         ---------------  -------------  -------  -------  ---  ---\n"
#~ "         Datenträger 0    Online        80 GB      0 B\n"

#~ msgid "Run the same command again."
#~ msgstr "Führen Sie denselben Befehl erneut aus."

#, no-wrap
#~ msgid ""
#~ "   A new disk, which corresponds to the USB stick that you plugged in,\n"
#~ "   appears in the list.\n"
#~ msgstr ""
#~ "   Eine neue Festplatte, die dem USB-Stick entspricht, den Sie eingesteckt haben,\n"
#~ "   erscheint in der Liste.\n"

#, no-wrap
#~ msgid "        Diskpart> list disk\n"
#~ msgstr "        Diskpart> list disk\n"

#, no-wrap
#~ msgid ""
#~ "          Disk ###  Status      Size     Free     Dyn  Gpt\n"
#~ "          --------  ----------  -------  -------  ---  ---\n"
#~ "          Disk 0    Online        80 GB      0 B\n"
#~ "          Disk 1    Online         8 GB      0 B\n"
#~ msgstr ""
#~ "          Datenträger ###  Status      Größe     Frei     Dyn  GPT\n"
#~ "          ---------------  -------------  -------  -------  ---  ---\n"
#~ "          Datenträger 0    Online        80 GB      0 B\n"
#~ "          Datenträger 1    Online         8 GB      0 B\n"

#, no-wrap
#~ msgid ""
#~ "   Make sure that its size corresponds to the size of the USB stick that you want to\n"
#~ "   reset. Note down its disk number.\n"
#~ msgstr ""
#~ "   Stellen Sie sicher, dass seine Größe der Größe des USB-Sticks entspricht, den Sie\n"
#~ "   zurücksetzen möchten. Notieren Sie sich die Festplattennummer.\n"

#, no-wrap
#~ msgid "   <p class=\"command-windows command-template\">select disk=<span class=\"command-placeholder\">number</span></p>\n"
#~ msgstr "   <p class=\"command-windows command-template\">Wählen Sie disk=<span class=\"command-placeholder\">nummer</span> aus</p>\n"

#, fuzzy
#~| msgid ""
#~| "Execute the <span class=\"command\">clean</span> command to delete the "
#~| "partition table from the USB stick."
#~ msgid ""
#~ "Execute the following command to delete the partition table from the USB "
#~ "stick."
#~ msgstr ""
#~ "Führen Sie den Befehl <span class=\"command\">clean</span> aus, um die "
#~ "Partitionstabelle von dem USB-Stick zu löschen."

#, no-wrap
#~ msgid "   <p class=\"command-windows\">clean</p>\n"
#~ msgstr "   <p class=\"command-windows\">clean</p>\n"

#, no-wrap
#~ msgid "   <p class=\"command-windows\">convert mbr</p>\n"
#~ msgstr "   <p class=\"command-windows\">convert mbr</p>\n"

#, no-wrap
#~ msgid "   <p class=\"command-windows\">create partition primary</p>\n"
#~ msgstr "   <p class=\"command-windows\">create partition primary</p>\n"

#~ msgid "Plug the USB stick again."
#~ msgstr "Stecken Sie den USB-Stick wieder ein."

#~ msgid "A dialog appears to format the disk before using it."
#~ msgstr ""
#~ "Ein Dialogfeld erscheint, um die Festplatte vor der Verwendung zu "
#~ "formatieren."

#, fuzzy, no-wrap
#~| msgid "   [[!img format.png link=\"no\" class=\"screenshot\" alt=\"You need to format the disk before you can use it. Do you want to format it?\"]]\n"
#~ msgid "   [[!img format.png class=\"screenshot\" alt=\"You need to format the disk before you can use it. Do you want to format it?\"]]\n"
#~ msgstr "   [[!img format.png link=\"no\" class=\"screenshot\" alt=\"Sie müssen die Festplatte formatieren, bevor Sie sie verwenden können. Möchten Sie sie formatieren?\"]]\n"

#~ msgid "Click on the **Format disk** button."
#~ msgstr "Klicken Sie auf die Schaltfläche **Festplatte formatieren**."

#~ msgid ""
#~ "In the **Format USB Drive** dialog, review the settings and click "
#~ "**Start**."
#~ msgstr ""
#~ "Überprüfen Sie im Dialogfeld **USB-Laufwerk formatieren** die "
#~ "Einstellungen und klicken Sie auf **Start**."

#~ msgid ""
#~ "After the formatting is complete, the USB stick should appear as a new "
#~ "drive in the files browser."
#~ msgstr ""
#~ "Nachdem die Formatierung abgeschlossen ist, sollte der USB-Stick als "
#~ "neues Laufwerk im Datei-Browser angezeigt werden."

#, no-wrap
#~ msgid "   Otherwise, try unplugging and plugging it again.\n"
#~ msgstr "   Andernfalls versuchen Sie, das Gerät erneut zu entfernen und wieder anzuschließen.\n"

