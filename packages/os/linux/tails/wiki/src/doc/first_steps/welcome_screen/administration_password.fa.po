#, fuzzy, no-wrap
msgid "How to open a root console"
msgstr "چگونه یک پایانهٔ اصلی باز کنیم"

#. type: Plain text
msgid ""
"To open a root console (also called *root terminal*), you can execute the "
"following command in a *Console*."
msgstr ""

#. type: Plain text
#, no-wrap
msgid "  <p class=\"command\">sudo -i</p>\n"
msgstr ""

