#~ msgstr "   Un nuevo disco, correspondiente a esa memoria USB, aparece en la lista.\n"

#, no-wrap
#~ msgid "        Diskpart> list disk\n"
#~ msgstr "        Diskpart> list disk\n"

#, no-wrap
#~ msgid ""
#~ "          Disk ###  Status      Size     Free     Dyn  Gpt\n"
