#~ msgstr "<a id=\"ftp\"></a>\n"

#~ msgid "Downloading files from an FTP server on the local network\n"
#~ msgstr ""
#~ "Télécharger des fichiers à partir d' un serveur FTP sur le réseau local\n"

#~ msgid "Open *Files*."
#~ msgstr "Ouvrez *Fichiers*."

#~ msgid "Click on **Other Locations** in the sidebar."
#~ msgstr "Cliquez sur **Autres emplacements** dans la barre latérale."

