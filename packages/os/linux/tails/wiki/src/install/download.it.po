#. type: Plain text
#, no-wrap
msgid "<h1 class=\"step\">Continue installing or upgrading Tails</h1>\n"
msgstr "<h1 class=\"step\">Continua a installare o aggiornare Tails</h1>\n"

#. type: Plain text
msgid "With this USB image, you can either:"
msgstr "Con questa immagine su USB è possibile:"

#. type: Bullet: '- '
msgid "Upgrade your Tails USB stick and keep your Persistent Storage."
msgstr "Aggiorna la tua chiavetta USB Tails e mantieni l'Archivio Persistente."

#. type: Bullet: '  * '
msgid "[[Upgrade from your Tails|doc/upgrade/tails]]"
msgstr "[[Aggiorna dal tuo Tails|doc/upgrade/tails]]"

#. type: Bullet: '  * '
msgid "[[Upgrade from Windows|doc/upgrade/windows]]"
msgstr "[[Aggiorna da Windows|doc/upgrade/windows]]"

#. type: Bullet: '  * '
msgid "[[Upgrade from macOS|doc/upgrade/mac]]"
msgstr "[[Aggiorna da macOS|doc/upgrade/mac]]"

#. type: Bullet: '  * '
msgid "[[Upgrade from Linux|doc/upgrade/linux]]"
msgstr "[Aggiorna da Linux|doc/upgrade/linux]]"

#. type: Bullet: '- '
msgid "Install a new Tails USB stick."
msgstr "Installa una nuova chiavetta USB di Tails."

#. type: Bullet: '  * '
msgid "<span class=\"button\">[[Install from Windows|install/windows]]</span>"
msgstr "<span class=\"button\">[[Installa da Windows|install/windows]]</span>"

#. type: Bullet: '  * '
msgid "<span class=\"button\">[[Install from macOS|install/mac]]</span>"
msgstr "<span class=\"button\">[[Installa da macOS|install/mac]]</span>"

#. type: Bullet: '  * '
msgid "<span class=\"button\">[[Install from Linux|install/linux]]</span>"
msgstr "<span class=\"button\">[[Installa da Linux|install/linux]]</span>"

#. type: Bullet: '  * '
msgid ""
"<span class=\"button\">[[Install from Debian or Ubuntu using the command "
"line and GnuPG|install/expert]]</span>"
msgstr ""
"<span class=\"button\">[[Installa da Debian o Ubuntu usando la linea di "
"comando e GnuPG|install/expert]]</span>"

#. type: Plain text
msgid "To burn a Tails DVD, download our [[ISO image|download-iso]] instead."
msgstr ""
"Per masterizzare un DVD di Tails, scarica invece la nostra [[immagine ISO|"
"download-iso]]."

