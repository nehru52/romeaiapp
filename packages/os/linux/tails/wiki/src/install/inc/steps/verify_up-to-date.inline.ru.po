msgid "[[!meta robots=\"noindex\"]]\n"
msgstr "[[!meta robots=\"noindex\"]]\n"

#. type: Plain text
#, no-wrap
msgid "<h1 id=\"verify-other\" class=\"step\">Verify that the other Tails is up-to-date</h1>\n"
msgstr "<h1 id=\"verify-other\" class=\"step\">Насколько свежая версия Tails?</h1>\n"

#. type: Plain text
#, fuzzy, no-wrap
#| msgid ""
#| "To prevent\n"
#| "<span class=\"install-clone mac-clone\">installing</span>\n"
#| "<span class=\"upgrade-clone\">upgrading to</span>\n"
#| "an outdated version of Tails with known security issues, make sure that the Tails you are\n"
#| "<span class=\"install-clone mac-clone\">installing</span>\n"
#| "<span class=\"upgrade-clone\">upgrading</span>\n"
#| "from is up-to-date:\n"
msgid ""
"To prevent\n"
"<span class=\"pc-clone mac-clone\">installing</span>\n"
"<span class=\"upgrade-clone\">upgrading to</span>\n"
"an outdated version of Tails with known security issues, make sure that the Tails you are\n"
"<span class=\"pc-clone mac-clone\">installing</span>\n"
"<span class=\"upgrade-clone\">upgrading</span>\n"
"from is up-to-date:\n"
msgstr ""
"Чтобы предотвратить\n"
"<span class=\"install-clone mac-clone\">установку</span>\n"
"<span class=\"upgrade-clone\">обновление до</span>\n"
"устаревшей версии Tails (с известными проблемами), убедитесь, что\n"
"<span class=\"install-clone mac-clone\">при установке</span>\n"
"<span class=\"upgrade-clone\">при обновлении</span>\n"
"имеете дело со свежей версией Tails.\n"

#. type: Bullet: '1. '
msgid "Choose **Apps&nbsp;▸ Tails&nbsp;▸ About Tails**."
msgstr "Выберите **Приложения&nbsp;▸ Tails&nbsp;▸ О Tails**."

#. type: Bullet: '1. '
msgid ""
"Verify that you are running **Tails [[!inline pages=\"inc/"
"stable_amd64_version\" raw=\"yes\" sort=\"age\"]]** released on [[!inline "
"pages=\"inc/stable_amd64_date\" raw=\"yes\" sort=\"age\"]]:"
msgstr ""
"Убедитесь, что используете <span class=\"guilabel\">Tails [[!inline "
"pages=\"inc/stable_amd64_version.ru\" raw=\"yes\" sort=\"age\"]]</span> от "
"[[!inline pages=\"inc/stable_amd64_date.ru\" raw=\"yes\" sort=\"age\"]]."

#. type: Bullet: '   - '
#, fuzzy
#| msgid ""
#| "   a. If you are running [[!inline pages=\"inc/stable_amd64_version\" "
#| "raw=\"yes\" sort=\"age\"]] then you can continue with the next step.\n"
msgid ""
"If you are running Tails [[!inline pages=\"inc/stable_amd64_version\" "
"raw=\"yes\" sort=\"age\"]], continue with the next step."
msgstr ""
"   а) Если вы используете [[!inline pages=\"inc/stable_amd64_version.ru\" "
"raw=\"yes\" sort=\"age\"]], можете перейти к следующему шагу.\n"

#. type: Bullet: '   - '
#, fuzzy
#| msgid ""
#| "   a. If you are running [[!inline pages=\"inc/stable_amd64_version\" "
#| "raw=\"yes\" sort=\"age\"]] then you can continue with the next step.\n"
msgid ""
"If you are not running Tails [[!inline pages=\"inc/stable_amd64_version\" "
"raw=\"yes\" sort=\"age\"]], click **Check for Upgrades**."
msgstr ""
"   а) Если вы используете [[!inline pages=\"inc/stable_amd64_version.ru\" "
"raw=\"yes\" sort=\"age\"]], можете перейти к следующему шагу.\n"

#. type: Plain text
#, no-wrap
msgid "     Apply all upgrades as requested.\n"
msgstr ""

