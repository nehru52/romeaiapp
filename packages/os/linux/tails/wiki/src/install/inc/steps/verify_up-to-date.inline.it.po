#. type: Plain text
#, no-wrap
msgid "[[!meta robots=\"noindex\"]]\n"
msgstr "[[!meta robots=\"noindex\"]]\n"

#. type: Plain text
#, no-wrap
msgid "<h1 id=\"verify-other\" class=\"step\">Verify that the other Tails is up-to-date</h1>\n"
msgstr "<h1 id=\"verify-other\" class=\"step\">Verifica che l'altro Tails sia aggiornato</h1>\n"

#. type: Plain text
#, no-wrap
msgid ""
"To prevent\n"
"<span class=\"pc-clone mac-clone\">installing</span>\n"
"<span class=\"upgrade-clone\">upgrading to</span>\n"
"an outdated version of Tails with known security issues, make sure that the Tails you are\n"
"<span class=\"pc-clone mac-clone\">installing</span>\n"
"<span class=\"upgrade-clone\">upgrading</span>\n"
"from is up-to-date:\n"
msgstr ""
"Per evitare di\n"
"<span class=\"pc-clone mac-clone\">nstallare</span>\n"
"<span class=\"upgrade-clone\">eseguire l'aggiornamento a</span>\n"
"una versione obsoleta di Tails con problemi di sicurezza noti, assicurati che il Tails dal quale stai\n"
"<span class=\"pc-clone mac-clone\"> installando</span>\n"
"<span class=\"upgrade-clone\">l'aggiornamento</span>\n"
"sia aggiornato:\n"

#. type: Bullet: '1. '
msgid "Choose **Apps&nbsp;▸ Tails&nbsp;▸ About Tails**."
msgstr "Seleziona **App&nbsp;▸ Tails&nbsp;▸ Informazioni su Tails**."

#. type: Bullet: '1. '
msgid ""
"Verify that you are running **Tails [[!inline pages=\"inc/"
"stable_amd64_version\" raw=\"yes\" sort=\"age\"]]** released on [[!inline "
"pages=\"inc/stable_amd64_date\" raw=\"yes\" sort=\"age\"]]:"
msgstr ""
"Verifica che sia in esecuzione <span class=\"guilabel\">Tails [[!inline "
"pages=\"inc/stable_amd64_version\" raw=\"yes\" sort=\"age\"]]</span> "
"rilasciato il [[!inline pages=\"inc/stable_amd64_date\" raw=\"yes\" "
"sort=\"age\"]]:"

#. type: Bullet: '   - '
msgid ""
"If you are running Tails [[!inline pages=\"inc/stable_amd64_version\" "
"raw=\"yes\" sort=\"age\"]], continue with the next step."
msgstr ""
"Se stai usandoTails "
"[[!inline pages=\"inc/stable_amd64_version\" raw=\"yes\" sort=\"age\"]], "
"continua con il passaggio successivo."

#. type: Bullet: '   - '
msgid ""
"If you are not running Tails [[!inline pages=\"inc/stable_amd64_version\" "
"raw=\"yes\" sort=\"age\"]], click **Check for Upgrades**."
msgstr ""
"Se non stai usando Tails "
"[[!inline pages=\"inc/stable_amd64_version\" raw=\"yes\" sort=\"age\"]], "
"clicca su **Verifica Aggiornamenti**."

#. type: Plain text
#, no-wrap
msgid "     Apply all upgrades as requested.\n"
msgstr "     Applica tutti gli aggiornamenti come richiesto.\n"

#, no-wrap
#~ msgid ""
#~ "   b. If you are not running [[!inline pages=\"inc/stable_amd64_version\" raw=\"yes\" sort=\"age\"]] then connect to the Internet\n"
#~ "   and to Tor. After a minute or two, *Tails Upgrader*\n"
#~ "   appears with instructions on how to upgrade. Apply all upgrades as requested.\n"
#~ msgstr ""
#~ "   b. Se non stai eseguendo la versione [[!inline pages=\"inc/stable_amd64_version\" raw=\"yes\" sort=\"age\"]] collegati a Internet\n"
#~ "   e a Tor. Dopo un minuto o due, appare il *Tails Upgrader*\n"
#~ "   con le istruzioni di aggiornamento. Applica tutti gli aggiornamenti come richiesto.\n"

