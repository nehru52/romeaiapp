#. type: Content of: <div>
msgid "[[!meta title=\"News\"]]"
msgstr "[[!meta title=\"Actualités\"]]"

#. type: Content of: <p>
msgid "Subscribe to our newsletter to receive the same news by email:"
msgstr ""
"Abonnez-vous à notre lettre d'information pour recevoir les mêmes actualités "
"par courrier électronique :"

#. type: Content of: <form>
msgid ""
"<input aria-label=\"Email\" name=\"email\" value=\"\"/> <button aria-"
"label=\"Subscribe\" class=\"button\" type=\"submit\">Subscribe</button>"
msgstr ""
"<input aria-label=\"Courrier électronique\" name=\"email\" value=\"\"/> "
"<button aria-label=\"S'abonner\" class=\"button\" type=\"submit\">S'abonner</"
"button>"

#. type: Content of: <form><p>
msgid "[[Archive of all news|news/archive]]"
msgstr "[[Archive de toutes les actualités|news/archive]]"

#.  Inlined news 
#.  Feed buttons used by puppet-code:site/profile/manifests/tails/website/rss2email.pp
#. [[!inline pages="page(news/*) and !news/archive and !news/*/* and !news/discussion and tagged(announce)"
#. show="10" feeds="yes" feedonly="yes" feedfile="emails" sort="-meta(date) age -path"]]
#. type: Content of: outside any tag (error?)
msgid ""
"[[!inline pages=\"page(news/*) and !news/archive and !news/*/* and !news/"
"discussion\" show=\"10\" sort=\"-meta(date) age -path\"]]"
msgstr "[[!inline pages=\"page(news/*) and !news/archive and !news/*/* and !news/discussion\" show=\"10\" sort=\"-meta(date) age -path\"]]"
