[Unit]
Description=Warn the user if elizaOS is running inside a virtual machine
Documentation=file:///usr/share/doc/elizaos/website/doc.en.html
After=tails-wait-until-htpdate-has-succeeded.service

[Service]
Type=oneshot
ExecStart=/usr/local/lib/tails-virt-notify-user
RemainAfterExit=yes

[Install]
WantedBy=desktop.target
