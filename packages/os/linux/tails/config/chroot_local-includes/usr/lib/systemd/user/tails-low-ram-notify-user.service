[Unit]
Description=Warn the user if the system has too little RAM installed
Documentation=file:///usr/share/doc/elizaos/website/doc.en.html
After=tails-wait-until-htpdate-has-succeeded.service

[Service]
Type=oneshot
ExecStart=/usr/local/lib/tails-low-ram-notify-user
RemainAfterExit=yes

[Install]
WantedBy=desktop.target
