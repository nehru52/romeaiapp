[Unit]
Description=Check available elizaOS base updates
Documentation=file:///usr/share/doc/elizaos/website/doc.en.html
After=tails-wait-until-tor-has-bootstrapped.service
ConditionPathExists=/etc/elizaos/base-updates-enabled

[Service]
ExecStart=/usr/local/bin/tails-upgrade-frontend-wrapper
RemainAfterExit=yes

[Install]
WantedBy=desktop.target
