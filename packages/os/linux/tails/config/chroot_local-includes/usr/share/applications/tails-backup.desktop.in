[Desktop Entry]
Type=Application
_Name=Back Up elizaOS Storage
_Comment=Back up elizaOS Persistent Storage to another elizaOS USB stick
_Keywords=elizaos;backup;persistent;storage
Icon=elizaos
Exec=/usr/bin/kgx --title 'elizaOS Storage Backup' -- /usr/local/bin/tails-backup
Terminal=false
Categories=System;Utility;
StartupNotify=false
