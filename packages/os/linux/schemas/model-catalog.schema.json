{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elizaos.ai/schemas/model-catalog.schema.json",
  "title": "elizaOS Live model catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "catalogVersion", "models"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "elizaos.modelCatalog"
    },
    "catalogVersion": {
      "type": "string",
      "minLength": 1
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "provider",
          "version",
          "modalities",
          "artifacts"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "modalities": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": ["text", "embedding", "image", "audio", "vision", "tool"]
            }
          },
          "capabilities": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "runtime": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "engine": {
                "type": "string",
                "minLength": 1
              },
              "minimumRuntimeVersion": {
                "type": "string",
                "minLength": 1
              },
              "accelerators": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "enum": ["cpu", "cuda", "metal", "vulkan"]
                }
              }
            }
          },
          "artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": {
                  "$ref": "#/$defs/relativePath"
                },
                "sha256": {
                  "$ref": "#/$defs/sha256"
                },
                "size": {
                  "type": "integer",
                  "minimum": 0
                },
                "mediaType": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          }
        }
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^/|(^|/)\\.\\.(/|$)|(^|/)\\.(/|$)|\\u0000"
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    }
  }
}
