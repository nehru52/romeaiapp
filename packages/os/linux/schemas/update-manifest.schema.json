{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elizaos.ai/schemas/update-manifest.schema.json",
  "title": "elizaOS Live update manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "manifestVersion",
    "channel",
    "sequence",
    "publishedAt",
    "runtime"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "elizaos.updateManifest"
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "minimumOsVersion": {
      "type": "string",
      "minLength": 1
    },
    "product": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "architectures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._-]+$"
      },
      "uniqueItems": true
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "bundlePath",
        "entrypoints",
        "filesComplete",
        "files"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "bundlePath": {
          "$ref": "#/$defs/relativePath"
        },
        "entrypoints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["bun", "launcher", "agent"],
          "properties": {
            "bun": {
              "$ref": "#/$defs/relativePath"
            },
            "launcher": {
              "$ref": "#/$defs/relativePath"
            },
            "agent": {
              "$ref": "#/$defs/relativePath"
            },
            "nodeModules": {
              "$ref": "#/$defs/relativePath"
            }
          }
        },
        "filesComplete": {
          "const": true
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": {
                "$ref": "#/$defs/relativePath"
              },
              "sha256": {
                "$ref": "#/$defs/sha256"
              },
              "size": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "modelCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^/|(^|/)\\.\\.(/|$)|(^|/)\\.(/|$)|\\u0000"
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    }
  }
}
