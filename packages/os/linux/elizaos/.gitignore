# live-build / debootstrap working state — large, often root-owned, recreated
# on every build. Never check in.
.build/
.lock
.ruff_cache/
cache/
chroot/
chroot.packages.install
chroot.packages.live
chroot.files
binary/
binary.modified_timestamps
live-image-*.contents
live-image-*.files
live-image-*.packages
local/

# lb config output (generated from auto/config — not source).
config/binary
config/bootstrap
config/chroot
config/common
config/debian-installer
config/source

# live-build stock hooks copied in by `lb config` (we only own the
# elizaos-* and profile hooks under hooks/normal/00*).
config/hooks/live/
config/hooks/normal/1*.hook.chroot
config/hooks/normal/5*.hook.chroot
config/hooks/normal/8*.hook.chroot
config/hooks/normal/9*.hook.chroot

# Build output ISOs — never commit; reference by sha256 in manifest.json.
out/

# mkosi build state — same policy as live-build's cache/chroot: never check in.
mkosi/mkosi.cache/
mkosi/mkosi.builddir/
mkosi/mkosi.output/
mkosi/.mkosi-*/

# Generated raster branding (produced from assets/*.svg at build time).
config/includes.chroot/usr/share/backgrounds/elizaos/*.png
config/includes.chroot/usr/share/icons/hicolor/*/apps/elizaos.png
config/includes.chroot/usr/share/plymouth/themes/elizaos/*.png
config/includes.binary/boot/grub/elizaos-splash.png
.build.lock
