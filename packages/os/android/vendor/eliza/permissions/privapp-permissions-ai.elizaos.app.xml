<?xml version="1.0" encoding="utf-8"?>
<!--
  Privileged-permission whitelist for ai.elizaos.app.

  Lists every signature|privileged permission the Eliza APK declares in
  its AndroidManifest. Without an entry here, PackageManager refuses to
  grant the permission even though the app is installed in /system/priv-app/,
  and `adb logcat` will show "Privileged permission ... not in
  privapp-permissions whitelist" at boot.

  When adding a new signature|privileged permission to the manifest,
  remember to add it here as well — otherwise the priv-app boot-time
  check will fail and the device will refuse to start the package.

  Read by PackageManager from /system/etc/permissions/.
  Soong module: see ../permissions/Android.bp (`prebuilt_etc`,
    sub_dir: "permissions").
-->
<permissions>
    <privapp-permissions package="ai.elizaos.app">
        <permission name="android.permission.PACKAGE_USAGE_STATS" />
        <!--
          Required by ElizaBootReceiver to flip the GET_USAGE_STATS
          appop to ALLOWED via reflection on AppOpsManager#setMode at
          sys.boot_completed. Without this the receiver throws
          SecurityException("uid X does not have MANAGE_APP_OPS_MODES")
          and the appop stays in default mode, breaking PACKAGE_USAGE_STATS.
        -->
        <permission name="android.permission.MANAGE_APP_OPS_MODES" />
        <!-- Required for AOSP/system builds that expose AVF/Microdroid. -->
        <permission name="android.permission.MANAGE_VIRTUAL_MACHINE" />
        <!-- Privileged computer-control path for AOSP/system images only. -->
        <permission name="android.permission.READ_FRAME_BUFFER" />
        <permission name="android.permission.INJECT_EVENTS" />
        <permission name="android.permission.REAL_GET_TASKS" />
        <!--
          System-level overlay used by ElizaVoicePillOverlayService to draw
          the voice pill on top of other apps via WindowManager with
          TYPE_APPLICATION_OVERLAY. On AOSP system-signed builds this is
          pre-granted; on sideload/Play APKs the user must grant it via
          Settings.canDrawOverlays + ACTION_MANAGE_OVERLAY_PERMISSION.
        -->
        <permission name="android.permission.SYSTEM_ALERT_WINDOW" />
    </privapp-permissions>
</permissions>
