# eliza-cloud local development secrets.
#
# Copy to .env (gitignored) and replace every placeholder with a real value:
#   cp .env.example .env
#
# Generate JWT secrets with: openssl rand -base64 48
# Generate S3 credentials with: openssl rand -hex 32
#
# These values are for LOCAL DEV ONLY. Production secrets are managed by
# external-secrets-operator pulling from the Steward credential proxy — never
# place production credentials in this file.

# --- Postgres (storage backing store) ---
STORAGE_DB_USER=postgres
STORAGE_DB_PASSWORD=replace-me-with-strong-password

# --- Supabase storage-api JWT / API keys ---
# ANON_KEY and SERVICE_KEY are JWTs signed by STORAGE_AUTH_JWT_SECRET (HS256).
# Mint them with the Supabase JWT tool or any HS256 signer.
STORAGE_ANON_KEY=replace-me-anon-jwt
STORAGE_SERVICE_KEY=replace-me-service-jwt
STORAGE_AUTH_JWT_SECRET=replace-me-min-32-chars
STORAGE_PGRST_JWT_SECRET=replace-me-min-32-chars

# --- S3-compatible protocol credentials ---
STORAGE_ACCESS_KEY_ID=replace-me-access-key
STORAGE_SECRET_ACCESS_KEY=replace-me-secret-key
