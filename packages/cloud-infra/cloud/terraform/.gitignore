# Sensitive files
secrets.tfvars
tfvars/secrets.tfvars
*.auto.tfvars

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Plan files
*.tfplan
plan.out
