  (text "J1 Samtec FTSH-105-01-F-DV-K\n10-pin 1.27mm ARM Cortex Debug (RISC-V JTAG)\nPin1=VTref(1V8+100R) Pin2=TMS(10k PU 1V8) Pin3=GND\nPin4=TCK(10k PD GND) Pin5=GND Pin6=TDO\nPin7=NC/KEY Pin8=TDI(10k PU 1V8) Pin9=GND Pin10=nRESET(100R)"
    (at 10 8)
    (effects (font (size 1.0 1.0)))
    (uuid "txt-j1-note")
  )

  (text "J2 UART Header 4-pin 2.54mm\nPin1=3.3V Pin2=GND Pin3=UART_TX Pin4=UART_RX\n3.3V CMOS direct - use 3.3V compatible FTDI adapter only"
    (at 105 35)
    (effects (font (size 1.0 1.0)))
    (uuid "txt-j2-note")
  )

  (text "J3 USB-C Power Only (USB4135-GF-A)\nVBUS → F1 (0.5A PTC) → VIN_5V\nCC1,CC2: 5.1k to GND (sink/ufp mode, no PD)\nD+, D-: No connect (power path only)"
    (at 10 108)
    (effects (font (size 1.0 1.0)))
    (uuid "txt-j3-note")
  )

  (text "Test Points TP1-TP8 (1mm TH gold pad)\nTP1=GPIO0 TP2=GPIO1 TP3=GPIO2 TP4=GPIO3\nTP5=IRQ_TIMER TP6=IRQ_DMA TP7=BOOT_SEL TP8=CLK_24M\nAll 1V8 CMOS; 100R series resistor on each GPIO/IRQ signal\nTP8 CLK: T-tap with 1nF AC-blocking cap, 50Ω trace"
    (at 140 8)
    (effects (font (size 1.0 1.0)))
    (uuid "txt-tp-note")
  )
