[tasks]
bmc

[options]
bmc: mode bmc
bmc: depth 80
multiclock off

[engines]
smtbmc z3

[script]
read -formal -sv e1_axi4_pkg.sv
read -formal -sv e1_display_scanout.sv
read -formal -sv e1_display_scanout_formal.sv
prep -top e1_display_scanout_formal

[files]
rtl/interconnect/axi4/e1_axi4_pkg.sv
rtl/display/e1_display_scanout.sv
verify/formal/e1_display_scanout_formal.sv
