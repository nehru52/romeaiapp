[options]
mode prove
depth 12
multiclock off

[engines]
smtbmc bitwuzla

[script]
read -define AXIL_PROTO_ASSUME_LIVENESS
read -formal -sv axi_lite_protocol.sv
read -formal e1_axi_lite_interconnect.sv
read -formal e1_axi_lite_interconnect_bind.sv
prep -top e1_axi_lite_interconnect_props_top

[files]
verify/properties/axi_lite_protocol.sv
rtl/interconnect/e1_axi_lite_interconnect.sv
verify/formal/e1_axi_lite_interconnect_bind.sv
