[tasks]
bmc
prove

[options]
bmc: mode bmc
bmc: depth 24
prove: mode prove
prove: depth 16
multiclock off

[engines]
smtbmc bitwuzla

[script]
read -formal -sv axi_lite_protocol.sv
read -formal -sv e1_interrupt_controller.sv
read -formal -sv e1_interrupt_controller_bind.sv
prep -top e1_interrupt_controller_props_top

[files]
verify/properties/axi_lite_protocol.sv
rtl/interrupts/e1_interrupt_controller.sv
verify/formal/e1_interrupt_controller_bind.sv
