[options]
mode bmc
depth 32
multiclock off

[engines]
smtbmc bitwuzla

[script]
read -define AXIL_PROTO_ASSUME_LIVENESS
read -formal -sv axi_lite_protocol.sv
read -formal -sv e1_dma.sv
read -formal -sv dma_axil_bind.sv
prep -top dma_axil_props_top

[files]
verify/properties/axi_lite_protocol.sv
rtl/dma/e1_dma.sv
verify/properties/dma_axil_bind.sv
