[tasks]
bmc
prove

[options]
bmc: mode bmc
bmc: depth 32
prove: mode prove
prove: depth 16
multiclock off

[engines]
bmc: smtbmc
prove: smtbmc

[script]
read -define AXIL_PROTO_ASSUME_LIVENESS
read -formal -sv axi_lite_protocol.sv
read -formal -sv e1_dma.sv
read -formal -sv dma_axil_bind.sv
prep -top dma_axil_props_top

[files]
axi_lite_protocol.sv
dma_axil_bind.sv
../../rtl/dma/e1_dma.sv
