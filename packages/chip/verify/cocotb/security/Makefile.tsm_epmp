include ../common.mk

VERILOG_SOURCES := \
	$(REPO)/rtl/security/tsm/e1_tsm_epmp_pkg.sv \
	$(REPO)/rtl/security/tsm/e1_tsm_epmp_wall.sv

TOPLEVEL ?= e1_tsm_epmp_wall
MODULE   ?= test_e1_tsm_epmp_wall

# DECLFILENAME: the package file name does not match its single package symbol
# (intentional pkg/module split). Lint is enforced strictly (no functional
# waivers) by scripts/check_tsm_epmp_wall.py.
EXTRA_ARGS += -Wno-DECLFILENAME

include $(COCOTB_SIM_MK)
