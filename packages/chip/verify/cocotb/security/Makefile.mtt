include ../common.mk

VERILOG_SOURCES := \
	$(REPO)/rtl/security/mtt/e1_mtt_pkg.sv \
	$(REPO)/rtl/security/mtt/e1_mtt_checker.sv

TOPLEVEL ?= e1_mtt_checker
MODULE   ?= test_e1_mtt_checker

# Width waivers for the parameterized radix-index / table-stride arithmetic in
# the DUT; lint is enforced strictly (no waivers) by scripts/check_mtt_checker.py.
EXTRA_ARGS += -Wno-WIDTHEXPAND -Wno-WIDTHTRUNC

include $(COCOTB_SIM_MK)
