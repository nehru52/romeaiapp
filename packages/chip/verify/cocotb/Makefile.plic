include common.mk

VERILOG_SOURCES := \
	$(REPO)/rtl/interrupts/e1_plic.sv

TOPLEVEL ?= e1_plic
MODULE   ?= test_plic_claim_threshold

# Four sources, two contexts in the testbench (ctx0=M-mode, ctx1=S-mode of
# hart0) to exercise priority/threshold arbitration and context isolation.
EXTRA_ARGS += -GNUM_SOURCES=4 -GNUM_CONTEXTS=2
EXTRA_ARGS += -Wno-DECLFILENAME

include $(COCOTB_SIM_MK)
