# Mandatory drivers/libraries for the eliza e1_chip_cpu_variant platform.
# Matches the fixed (non-FDT) drivers referenced by platform.c:
#   ns16550a UART (uart8250), RISC-V PLIC, ACLINT MTIMER + MSWI (CLINT).
config PLATFORM_ELIZA
	bool
	select IPI_MSWI
	select IRQCHIP_PLIC
	select SERIAL_UART8250
	select TIMER_MTIMER
	default y
