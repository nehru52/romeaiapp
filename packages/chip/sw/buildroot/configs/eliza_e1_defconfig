# Minimal Buildroot defconfig for the Eliza e1 software BSP.
#
# This file is meant to be copied into an external Buildroot tree as:
#   configs/eliza_e1_defconfig
#
# It is not a checked-in Buildroot release. The checked-in source contract is
# sw/platform/e1_platform_contract.json, with generated constants such as
# E1_NPU_BASE, E1_DMA_BASE, and E1_DISPLAY_BASE.
BR2_riscv=y
BR2_RISCV_64=y
BR2_RISCV_ISA_RVA=y
BR2_RISCV_ISA_RVC=y
BR2_RISCV_ISA_RVD=y
BR2_RISCV_ISA_RVF=y
BR2_RISCV_ABI_LP64D=y
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
# Pin the toolchain kernel-headers series to the newest release Buildroot
# 2024.11 recognises. The e1 kernel below is a custom 6.12.x build, which is
# newer than this series, so the headers version check runs in loose mode
# (BR2_KERNEL_HEADERS_LATEST) instead of failing the strict equality test.
BR2_KERNEL_HEADERS_6_11=y
BR2_INIT_BUSYBOX=y
BR2_SYSTEM_DHCP="eth0"
BR2_TARGET_GENERIC_HOSTNAME="eliza-e1"
BR2_TARGET_GENERIC_ISSUE="Eliza e1 BSP"
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_ELIZA_E1_PATH)/board/eliza/e1/rootfs_overlay"
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="6.12.90"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_ELIZA_E1_PATH)/board/eliza/e1/linux.fragment"
BR2_LINUX_KERNEL_DTS_SUPPORT=y
BR2_LINUX_KERNEL_CUSTOM_DTS_PATH="$(BR2_EXTERNAL_ELIZA_E1_PATH)/../linux/dts/eliza-e1.dts"
BR2_TARGET_ROOTFS_CPIO=y
BR2_TARGET_ROOTFS_CPIO_GZIP=y
BR2_PACKAGE_ELIZA_E1_BSP=y
BR2_PACKAGE_E1_MMIO_SMOKE=y
BR2_PACKAGE_E1_NPU_ML_SMOKE=y
