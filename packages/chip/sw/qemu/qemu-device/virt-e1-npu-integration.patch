@@ -1151,6 +1174,10 @@ static void finalize_fdt(RISCVVirtState *s)
     create_fdt_uart(s, irq_mmio_phandle);
 
     create_fdt_rtc(s, irq_mmio_phandle);
+
+    if (s->e1_npu) {
+        create_fdt_e1_npu(s, irq_mmio_phandle);
+    }
 }
 
