     /* SiFive Test MMIO device */
     sifive_test_create(s->memmap[VIRT_TEST].base);
 
+    /* Eliza E1 NPU MMIO device */
+    if (s->e1_npu) {
+        DeviceState *npu = qdev_new(TYPE_ELIZA_E1_NPU);
+        SysBusDevice *npu_sbd = SYS_BUS_DEVICE(npu);
+
+        sysbus_realize_and_unref(npu_sbd, &error_fatal);
+        sysbus_mmio_map(npu_sbd, 0, s->memmap[VIRT_E1_NPU].base);
+        sysbus_connect_irq(npu_sbd, 0,
+                           qdev_get_gpio_in(mmio_irqchip, E1_NPU_IRQ));
+    }
+
     /* VirtIO MMIO devices */
     for (i = 0; i < VIRTIO_COUNT; i++) {
         sysbus_create_simple("virtio-mmio",
@@ -1828,6 +1866,20 @@ static void virt_set_aclint(Object *obj, bool value, Error **errp)
     s->have_aclint = value;
 }
 
+static bool virt_get_e1_npu(Object *obj, Error **errp)
+{
+    RISCVVirtState *s = RISCV_VIRT_MACHINE(obj);
+
+    return s->e1_npu;
+}
+
+static void virt_set_e1_npu(Object *obj, bool value, Error **errp)
+{
+    RISCVVirtState *s = RISCV_VIRT_MACHINE(obj);
+
+    s->e1_npu = value;
+}
+
 bool virt_is_iommu_sys_enabled(RISCVVirtState *s)
 {
     return s->iommu_sys == ON_OFF_AUTO_ON;
@@ -1978,6 +2030,12 @@ static void virt_machine_class_init(ObjectClass *oc, const void *data)
                               NULL, NULL);
     object_class_property_set_description(oc, "iommu-sys",
                                           "Enable IOMMU platform device");
+
+    object_class_property_add_bool(oc, "e1-npu", virt_get_e1_npu,
