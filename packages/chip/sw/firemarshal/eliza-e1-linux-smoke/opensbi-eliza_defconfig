# The generated AP is single-hart for this smoke path. OpenSBI generic
# fdt_ipi_init can stall while probing/touching the CLINT MSWI half; Linux
# does not need an SBI IPI device before userspace smoke starts.
# CONFIG_FDT_IPI is not set
# CONFIG_FDT_IPI_MSWI is not set
# OpenSBI hangs in the generic FDT PLIC cold init on the generated AP path.
# Linux still receives the PLIC node in the DTB and probes it in S-mode.
# CONFIG_FDT_IRQCHIP is not set
# CONFIG_FDT_IRQCHIP_PLIC is not set
CONFIG_FDT_RESET=y
CONFIG_FDT_RESET_HTIF=y
CONFIG_FDT_RESET_SIFIVE_TEST=y
CONFIG_FDT_SERIAL=y
CONFIG_FDT_SERIAL_SIFIVE=y
CONFIG_FDT_TIMER=y
CONFIG_FDT_TIMER_MTIMER=y
