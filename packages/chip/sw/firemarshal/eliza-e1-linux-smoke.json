{
  "name": "eliza-e1-linux-smoke",
  "base": "br-base.json",
  "distro": {
    "name": "br",
    "opts": {
      "configs": ["eliza-e1-linux-smoke-br-trim"]
    }
  },
  "linux-config": "eliza-e1-linux-smoke-kfrag",
  "overlay": "eliza-e1-linux-smoke-overlay",
  "host-init": "build-hwprobe.sh",
  "files": [
    ["eliza-e1-linux-smoke.sh", "/usr/bin/eliza-e1-linux-smoke"],
    ["eliza-riscv-hwprobe", "/usr/bin/eliza-riscv-hwprobe"],
    ["e1-npu-ml-smoke", "/usr/bin/e1-npu-ml-smoke"]
  ],
  "command": "/usr/bin/eliza-e1-linux-smoke",
  "firmware": {
    "opensbi-build-args": "FW_PAYLOAD_FDT_ADDR=0x80b00000 FW_OPTIONS=0 PLATFORM_DEFCONFIG=eliza_defconfig"
  }
}
