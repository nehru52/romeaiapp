{
  "name": "eliza-e1-ap-benchmarks",
  "base": "br-base.json",
  "distro": {
    "name": "br",
    "opts": {
      "configs": ["eliza-e1-ap-benchmarks-br-trim"]
    }
  },
  "linux-config": "eliza-e1-ap-benchmarks-kfrag",
  "files": [
    ["eliza-e1-ap-benchmarks.sh", "/usr/bin/eliza-e1-ap-benchmarks"],
    ["bin/ap-bench-lite", "/usr/bin/ap-bench-lite"],
    ["bin/coremark", "/usr/bin/coremark"],
    ["bin/stream_c.exe", "/usr/bin/stream_c.exe"],
    ["bin/lat_mem_rd", "/usr/bin/lat_mem_rd"],
    ["bin/fio", "/usr/bin/fio"],
    ["ufs-dram-contention.fio", "/root/ufs-dram-contention.fio"]
  ],
  "command": "/usr/bin/eliza-e1-ap-benchmarks",
  "firmware": {
    "opensbi-build-args": "FW_PAYLOAD_FDT_ADDR=0x84000000 FW_OPTIONS=0 PLATFORM_DEFCONFIG=eliza_defconfig"
  }
}
