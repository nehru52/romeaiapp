      "validation_command": "python3 scripts/check_software_bsp.py aosp --require-evidence",
      "external_artifacts": [
        "AOSP-built kernel or image artifacts",
        "QEMU console or adb transport"
      ]
    },
    {
      "path": "docs/evidence/android/eliza_ai_soc_cvd_hal_smoke.log",
      "claim": "Cuttlefish riscv64 booted, the e1_npu simulator HAL service registered, and lshal reported vendor.eliza.e1_npu@1.0::IE1Npu/default as available",
      "claim_boundary": "virtual_device_smoke_only_not_boot_or_compatibility_evidence",
      "capture_command": "sw/aosp-device/check-cvd-hal-smoke.sh /path/to/aosp",
      "validation_command": "python3 scripts/check_software_bsp.py aosp --require-evidence",
      "external_artifacts": [
        "Cuttlefish instance adb transport",
        "/vendor/bin/hw/vendor.eliza.e1_npu@1.0-service.sim"
      ]
    },
    {
      "path": "docs/evidence/android/renode_e1_soc_smoke.log",
      "claim": "Reference-only Renode smoke ran against the OpenAgent model; this is not Android compatibility evidence or a silicon boot claim",
      "claim_boundary": "virtual_device_smoke_only_not_boot_or_compatibility_evidence",
      "capture_command": "renode sim/renode/eliza_e1.resc with Android-capable firmware/kernel handoff when available",
      "validation_command": "python3 scripts/check_software_bsp.py aosp --require-evidence",
      "external_artifacts": [
        "Renode monitor transcript",
        "UART smoke transcript"
