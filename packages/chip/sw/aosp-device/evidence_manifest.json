  "blocked_until": [
    "External AOSP checkout is present and imported",
    "vendor.img build transcript is archived",
    "VINTF check transcript is archived",
    "SELinux policy build transcript is archived",
    "SELinux neverallow transcript is archived",
    "CTS/VTS scope-intake transcript is archived without a compatibility claim",
    "Cuttlefish, QEMU, and Renode virtual-device smoke transcripts are archived without Android boot or compatibility claims",
