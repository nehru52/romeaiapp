      "validation_command": "python3 scripts/check_software_bsp.py aosp --require-evidence",
      "external_artifacts": [
        "out/target/product/eliza_ai_soc/vendor.img",
        "out/target/product/eliza_ai_soc/installed-files-vendor.txt",
