menuconfig ELIZA_E1_BSP
	tristate "Eliza e1 BSP drivers"
	depends on OF
	help
	  Enables importable Linux drivers for the Eliza e1 platform
	  contract described by sw/platform/e1_platform_contract.json.

if ELIZA_E1_BSP

config ELIZA_E1_NPU
	tristate "Eliza e1 NPU contract driver"
	help
	  Exposes the eliza,e1-npu MMIO node through /dev/e1-npu for
	  smoke tests. The register base is E1_NPU_BASE in the platform
	  contract.

config ELIZA_E1_DMA
	tristate "Eliza e1 DMA contract driver"
	help
	  Binds the eliza,e1-dma MMIO node and exports a read-only sysfs
	  contract file for fast BSP validation.

endif
