#!/usr/bin/env python3
import sys
import time

size_arg = sys.argv[1] if len(sys.argv) > 1 else "64M"
if size_arg.lower().endswith("m"):
    size = int(float(size_arg[:-1]) * 1024 * 1024)
else:
    size = int(size_arg)
buf = bytearray(size)
start = time.perf_counter()
checksum = 0
for offset in range(0, size, 4096):
    checksum ^= buf[offset]
elapsed = max(time.perf_counter() - start, 1e-9)
print(f"{size / (1024 * 1024):.2f} {size / elapsed / 1_000_000.0:.3f}")
print(f"# checksum={checksum}")
