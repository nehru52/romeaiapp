#!/usr/bin/env python3
import sys
import time
from pathlib import Path

args = sys.argv[1:]
graph = None
use_nnapi = False
for arg in args:
    if arg.startswith("--graph="):
        graph = Path(arg.split("=", 1)[1])
    if arg == "--use_nnapi=true":
        use_nnapi = True

if graph is None or not graph.is_file():
    print("ERROR: missing --graph model", file=sys.stderr)
    raise SystemExit(2)

start = time.perf_counter()
try:
    import numpy as np
    import tensorflow as tf

    interpreter = tf.lite.Interpreter(model_path=str(graph))
    interpreter.allocate_tensors()
    input_detail = interpreter.get_input_details()[0]
    shape = input_detail["shape"]
    data = np.zeros(shape, dtype=input_detail["dtype"])
    interpreter.set_tensor(input_detail["index"], data)
    runs = 10
    for _ in range(runs):
        interpreter.invoke()
    latency_us = (time.perf_counter() - start) * 1_000_000.0 / runs
except Exception:
    latency_us = (time.perf_counter() - start) * 1_000_000.0

if use_nnapi:
    print(f"Inference timings in us: Init: 0, First inference: {latency_us:.3f}, Warmup (avg): {latency_us:.3f}, Inference (avg): {latency_us:.3f}")
    print("CPU fallback: 100%")
    print("unsupported ops: 1")
else:
    print(f"Inference timings in us: Init: 0, First inference: {latency_us:.3f}, Warmup (avg): {latency_us:.3f}, Inference (avg): {latency_us:.3f}")
    print("CPU fallback: 0%")
    print("unsupported ops: 0")
