{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "eliza.autovec_kernels.v1",
  "description": "30 short RVV autovec health kernels; covers bandwidth, predication, strided, reduction, quantization, shuffle, conv2d, attention. Used to compare LLVM-stock vs the trunk pin in compiler/llvm-build/llvm-pin.json.",
  "kernels": [
    {
      "name": "saxpy",
      "group": "trivial",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true
    },
    {
      "name": "daxpy",
      "group": "trivial",
      "elem_type": "f64",
      "n": 4096,
      "expected_vectorized": true
    },
    {
      "name": "dot_product",
      "group": "trivial",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true
    },
    {
      "name": "l2_norm",
      "group": "trivial",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true
    },
    {
      "name": "cond_mask_add",
      "group": "conditional",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true
    },
    {
      "name": "cond_mask_mul",
      "group": "conditional",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true
    },
    {
      "name": "strided_load_2",
      "group": "stride",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true,
      "notes": "LLVM weakness vs GCC"
    },
    {
      "name": "strided_load_4",
      "group": "stride",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true,
      "notes": "LLVM weakness vs GCC"
    },
    {
      "name": "sum_reduction",
      "group": "reduction",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true
    },
    {
      "name": "max_reduction",
      "group": "reduction",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true
    },
    {
      "name": "argmax",
      "group": "reduction",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true
    },
    {
      "name": "int8_quantize",
      "group": "quantization",
      "elem_type": "i8",
      "n": 16384,
      "expected_vectorized": true
    },
    {
      "name": "int8_dequantize",
      "group": "quantization",
      "elem_type": "i8",
      "n": 16384,
      "expected_vectorized": true
    },
    {
      "name": "bit_reverse_byte",
      "group": "shuffle",
      "elem_type": "i8",
      "n": 16384,
      "expected_vectorized": true
    },
    {
      "name": "packed_uint8_to_uint16",
      "group": "shuffle",
      "elem_type": "i8",
      "n": 16384,
      "expected_vectorized": true
    },
    {
      "name": "softmax_inplace",
      "group": "reduction",
      "elem_type": "f32",
      "n": 1024,
      "expected_vectorized": true,
      "notes": "exp + reciprocal sum loop"
    },
    {
      "name": "memcpy_byte",
      "group": "bandwidth",
      "elem_type": "i8",
      "n": 65536,
      "expected_vectorized": true,
      "notes": "tests vle8.v/vse8.v store-loop"
    },
    {
      "name": "strlen_simple",
      "group": "bandwidth",
      "elem_type": "i8",
      "n": 4096,
      "expected_vectorized": false,
      "notes": "data-dependent loop exit; LLVM trunk handles via vsetvli + masked compare"
    },
    {
      "name": "dot_product_f32_unrolled4",
      "group": "trivial",
      "elem_type": "f32",
      "n": 8192,
      "expected_vectorized": true,
      "notes": "manual 4-way unroll; LLVM should re-vectorize over LMUL"
    },
    {
      "name": "conv2d_3x3_f32",
      "group": "nn",
      "elem_type": "f32",
      "h": 128,
      "w": 128,
      "expected_vectorized": true,
      "notes": "9-point stencil, inner ow loop is bandwidth-bound"
    },
    {
      "name": "layernorm_f32",
      "group": "nn",
      "elem_type": "f32",
      "n": 4096,
      "expected_vectorized": true,
      "notes": "two reduction passes plus pointwise rescale"
    },
    {
      "name": "gelu_tanh_f32",
      "group": "nn",
      "elem_type": "f32",
      "n": 4096,
      "expected_vectorized": true,
      "notes": "tanh approximation; vector tanhf must be lowered"
    },
    {
      "name": "silu_f32",
      "group": "nn",
      "elem_type": "f32",
      "n": 4096,
      "expected_vectorized": true,
      "notes": "expf + sigmoid divide"
    },
    {
      "name": "rope_f32",
      "group": "nn",
      "elem_type": "f32",
      "seq": 1024,
      "dim": 128,
      "expected_vectorized": true,
      "notes": "interleaved even/odd channels; depends on segment store"
    },
    {
      "name": "saxpy_i8",
      "group": "quantization",
      "elem_type": "i8",
      "n": 16384,
      "expected_vectorized": true,
      "notes": "saturating arithmetic on INT8"
    },
    {
      "name": "sum_i16",
      "group": "reduction",
      "elem_type": "i16",
      "n": 16384,
      "expected_vectorized": true,
      "notes": "widening reduction to INT32"
    },
    {
      "name": "gather_sum_f32",
      "group": "stride",
      "elem_type": "f32",
      "n": 4096,
      "expected_vectorized": true,
      "notes": "indexed gather; LLVM lowers via vluxei32.v"
    },
    {
      "name": "memset_byte",
      "group": "bandwidth",
      "elem_type": "i8",
      "n": 65536,
      "expected_vectorized": true,
      "notes": "vse8.v with broadcast"
    },
    {
      "name": "histogram_u8",
      "group": "stride",
      "elem_type": "i8",
      "n": 16384,
      "expected_vectorized": false,
      "notes": "scatter-modify-scatter; modern LLVM can vectorize via vluxei + vsuxei but bin collisions usually defeat it"
    },
    {
      "name": "trmv_l_f32",
      "group": "nn",
      "elem_type": "f32",
      "n": 256,
      "expected_vectorized": true,
      "notes": "triangular access pattern; inner loop short on small i"
    }
  ],
  "comparison_recipe": {
    "stock_baseline_compiler": "apt-installed clang (Ubuntu 24.04 default, typically clang-18 as of 2026-05-19)",
    "trunk_pin_compiler": "build/llvm-stage2/bin/clang built per compiler/llvm-build/llvm-pin.json",
    "evidence_record": "build/reports/compiler/autovec-trunk-vs-stock.json",
    "summary_record": "build/reports/compiler/autovec-trunk-vs-stock.md",
    "geomean_metric": "vector_instructions_per_kernel and qemu-user microseconds per kernel"
  }
}
