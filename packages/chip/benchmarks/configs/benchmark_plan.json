    {
      "name": "npu_arch_sim_open_2028",
      "suite": "Eliza deterministic NPU architecture simulator",
      "version": "local/open-scale-v1",
      "command": [
        "python3",
        "benchmarks/sim/run_npu_scale_sim.py",
        "--config",
        "open_2028_first_50tops"
      ],
      "requires": ["python3"],
      "input_dataset": "deterministic GEMM/conv/attention sweep",
      "primary_metric": "modeled dense INT8 TOPS",
      "units": "TOPS",
      "parser": "eliza_npu_scale_sim_v1",
      "provenance": "simulator",
      "required_metrics": [
        "min_observed_tops",
        "max_observed_tops",
        "min_utilization_percent",
        "total_descriptors_required",
        "max_descriptor_queue_passes",
        "total_dma_beats",
        "process_corner_count",
        "worst_process_corner_min_observed_tops"
      ],
      "timeout_seconds": 60
    },
