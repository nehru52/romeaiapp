    {
      "name": "tflite_cpu",
      "suite": "TensorFlow Lite benchmark_model",
      "version": "upstream/local",
      "command": [
        "benchmark_model",
        "--graph=benchmarks/models/mobile_smoke.tflite",
        "--num_threads=1",
        "--use_nnapi=false"
      ],
      "requires": ["benchmark_model"],
      "model_artifacts": [
        {
          "path": "benchmarks/models/mobile_smoke.tflite",
          "sha256": "6bb01f97e01d782b139eecf32fecada42c08a8edc8d2148da4dcf63b22dd972a",
          "placeholder_allowed": false,
          "min_size_bytes": 6144,
          "sha256_pin_note": "Architecture is conv+relu+fc+softmax; pinned from deterministic generation on TF 2.21.0 + tf-keras 2.21.0 (Python 3.12.11, macOS arm64).",
          "blocker_id": "TFLITE_SMOKE_MODEL_MISSING",
          "pipeline_visible": true,
          "release_blocking": true,
          "resolution": "Run benchmarks/models/generate_mobile_smoke_tflite.py in an environment with TensorFlow installed, or supply a redistributable TFLite model and pin sha256.",
          "generator": {
            "command": [
              "python3",
              "benchmarks/models/generate_mobile_smoke_tflite.py",
              "--out",
              "benchmarks/models/mobile_smoke.tflite"
            ],
            "network": "none",
            "deterministic": true
          }
        }
      ],
      "install": "Build TensorFlow Lite benchmark_model for the target and generate or supply a non-proprietary smoke .tflite model at benchmarks/models/mobile_smoke.tflite.",
      "input_dataset": "mobile_smoke.tflite synthetic input",
      "primary_metric": "inference latency",
      "units": "us",
      "parser": "tflite_benchmark_model",
      "required_metadata": [
        "software",
        "clocks",
        "memory",
        "thermal",
        "power",
        "process",
        "calibration"
      ],
      "required_metrics": ["avg_latency_us"],
      "required_calibration_assets": [
        "clock_source",
        "power_meter",
        "tflite_benchmark_model",
        "tflite_model"
      ],
      "timeout_seconds": 600
    },
    {
      "name": "e1_npu_mlperf_inference_modeled",
      "suite": "MLPerf Inference modeled subset",
      "version": "local/modeled-v1",
      "command": [
        "python3",
        "benchmarks/mlperf/run_mlperf_inference.py",
        "--query-count",
        "64"
      ],
      "requires": ["python3"],
      "input_dataset": "deterministic tiny INT8 MLP synthetic dataset",
      "primary_metric": "SingleStream p90 query latency",
      "units": "ns",
      "parser": "eliza_mlperf_inference_v1",
      "provenance": "simulator",
      "required_metrics": [
        "min_top1_accuracy",
        "single_stream_p90_latency_ns",
        "offline_throughput_samples_per_second",
        "energy_joules_per_inference",
        "npu_macs_total",
        "npu_commands_total"
      ],
      "metric_gates": [
        { "metric": "min_top1_accuracy", "op": "==", "value": 1.0 }
      ],
      "timeout_seconds": 60
    },
    {
      "name": "tflite_e1_npu",
      "suite": "TensorFlow Lite benchmark_model",
      "version": "upstream/local",
      "command": [
        "benchmark_model",
        "--graph=benchmarks/models/mobile_smoke.tflite",
        "--use_nnapi=true",
        "--nnapi_accelerator_name=e1-npu"
      ],
      "requires": ["benchmark_model"],
      "capability_artifacts": [
        {
          "path": "benchmarks/capabilities/e1_npu_nnapi.proof.json",
          "blocker_id": "E1_NPU_NNAPI_ACCELERATOR_MISSING",
          "blocked_reason": "missing_e1_npu_nnapi_accelerator",
          "pipeline_visible": true,
          "release_blocking": true,
          "resolution": "Run scripts/android/capture_e1_npu_nnapi_evidence.sh on an Android/Linux target exposing a real e1-npu NNAPI accelerator or delegate. Set E1_NPU_WRITE_PROOF_JSON=1 plus measured E1_NPU_MACS_PER_INFERENCE, E1_NPU_CYCLES, E1_NPU_HZ, E1_NPU_DMA_BYTES_READ, E1_NPU_DMA_BYTES_WRITTEN, E1_NPU_NNAPI_DELEGATED_NODE_COUNT, E1_NPU_NNAPI_TOTAL_NODE_COUNT, E1_NPU_CPU_FALLBACK_PERCENT=0, E1_NPU_UNSUPPORTED_OP_COUNT=0, E1_NPU_DATAFLOW_NAME, E1_NPU_GENERATED_BY, and E1_NPU_TARGET so the hardware validation job creates the proof JSON and transcripts together, not by hand.",
          "proof": {
            "schema": "eliza.e1_npu_nnapi_capability.v1",
            "accelerator_name": "e1-npu",
            "max_cpu_fallback_percent": 0,
            "max_unsupported_op_count": 0,
            "required_json_fields": [
              "capability.claim_level",
              "capability.precision",
              "dataflow.name",
              "dma.path",
              "dma.bytes_read",
              "dma.bytes_written",
              "dma.trace_bytes",
              "measurements.macs_per_inference",
              "measurements.npu_cycles",
              "measurements.npu_hz",
              "measurements.observed_tops",
              "measurements.tops_formula",
              "capture.commands.adb_devices",
              "capture.commands.nnapi_accelerator_query",
              "capture.commands.benchmark_model_nnapi",
              "capture.commands.dma_trace"
            ],
            "required_model_artifacts": [
              "benchmarks/models/mobile_smoke.tflite"
            ],
            "required_files": [
              "adb_devices",
              "nnapi_accelerator_query",
              "benchmark_model_nnapi",
              "dma_trace"
            ],
            "required_transcript_markers": {
              "adb_devices": ["device"],
              "nnapi_accelerator_query": ["e1-npu"],
              "benchmark_model_nnapi": [
                "--use_nnapi=true",
                "--nnapi_accelerator_name=e1-npu",
                "NNAPI"
              ],
              "dma_trace": ["e1-npu", "DMA", "bytes_read", "bytes_written"]
            }
          }
        }
      ],
      "model_artifacts": [
        {
          "path": "benchmarks/models/mobile_smoke.tflite",
          "sha256": "6bb01f97e01d782b139eecf32fecada42c08a8edc8d2148da4dcf63b22dd972a",
          "placeholder_allowed": false,
          "min_size_bytes": 6144,
          "sha256_pin_note": "Architecture is conv+relu+fc+softmax; pinned from deterministic generation on TF 2.21.0 + tf-keras 2.21.0 (Python 3.12.11, macOS arm64).",
          "blocker_id": "TFLITE_SMOKE_MODEL_MISSING",
          "pipeline_visible": true,
          "release_blocking": true,
          "resolution": "Run benchmarks/models/generate_mobile_smoke_tflite.py in an environment with TensorFlow installed, or supply a redistributable TFLite model and pin sha256.",
          "generator": {
            "command": [
              "python3",
              "benchmarks/models/generate_mobile_smoke_tflite.py",
              "--out",
              "benchmarks/models/mobile_smoke.tflite"
            ],
            "network": "none",
            "deterministic": true
          }
        }
      ],
      "install": "Build TensorFlow Lite benchmark_model with NNAPI support and generate or supply a non-proprietary smoke .tflite model at benchmarks/models/mobile_smoke.tflite.",
      "input_dataset": "mobile_smoke.tflite synthetic input",
      "primary_metric": "inference latency",
      "units": "us",
      "parser": "tflite_benchmark_model",
      "required_metadata": [
        "software",
        "clocks",
        "memory",
        "thermal",
        "power",
        "process",
        "calibration"
      ],
      "required_metrics": [
        "avg_latency_us",
        "unsupported_op_count",
        "cpu_fallback_percent"
      ],
      "required_calibration_assets": [
        "clock_source",
        "power_meter",
        "tflite_benchmark_model",
        "tflite_model",
        "nnapi_driver"
      ],
      "metric_gates": [
        { "metric": "unsupported_op_count", "op": "==", "value": 0 },
        { "metric": "cpu_fallback_percent", "op": "<=", "value": 0 }
      ],
      "timeout_seconds": 600
    },
