{
  "version": "0.1",
  "benchmarks": [
    {
      "name": "coremark",
      "suite": "CoreMark",
      "version": "upstream/local",
      "command": ["coremark"],
      "requires": ["coremark"],
      "install": "Build EEMBC CoreMark for the target and place the real coremark executable on PATH, or run scripts/install_coremark_stream_tools.sh --coremark-src <upstream-coremark> --only coremark to install it into tools/bin.",
      "input_dataset": "default",
      "primary_metric": "CoreMark/MHz",
      "units": "score_per_mhz",
      "parser": "coremark_v1",
      "required_metadata": [
        "software",
        "clocks",
        "memory",
        "thermal",
        "power",
        "process",
        "calibration"
      ],
      "required_metrics": ["coremark_per_mhz"],
      "required_calibration_assets": [
        "clock_source",
        "power_meter",
        "coremark_binary"
      ],
      "timeout_seconds": 300
    },
    {
      "name": "stream",
      "suite": "STREAM",
      "version": "upstream/local",
      "command": ["stream_c.exe"],
      "requires": ["stream_c.exe"],
      "install": "Compile STREAM from source for the target compiler, keep the executable named stream_c.exe, and place it on PATH, or run scripts/install_coremark_stream_tools.sh --stream-src <upstream-stream> --only stream to install it into tools/bin.",
      "input_dataset": "default arrays",
      "primary_metric": "Triad bandwidth",
      "units": "MB/s",
      "parser": "stream_v5",
      "required_metadata": [
        "software",
        "clocks",
        "memory",
        "thermal",
        "power",
        "process",
        "calibration"
