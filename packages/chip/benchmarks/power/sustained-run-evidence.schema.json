{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Eliza sustained power/thermal evidence manifest",
  "type": "object",
  "required": [
    "schema",
    "status",
    "claim_boundary",
    "target",
    "workload",
    "measurement_environment",
    "instrumentation",
    "artifacts",
    "computed_metrics",
    "release_blockers"
  ],
  "properties": {
    "schema": {
      "const": "eliza.sustained_power_thermal_evidence.v1"
    },
    "status": {
      "enum": ["blocked", "draft_local_evidence", "complete_measured_evidence"]
    },
    "claim_boundary": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "required": ["name", "substrate", "board_serial", "soc_revision"],
      "properties": {
        "name": { "type": "string" },
        "substrate": {
          "enum": [
            "local_estimate_only",
            "fpga",
            "dev_board",
            "prototype_silicon",
            "complete_phone"
          ]
        },
        "board_serial": { "type": "string" },
        "soc_revision": { "type": "string" }
      }
    },
    "workload": {
      "type": "object",
      "required": ["plan_id", "duration_seconds", "warmup_seconds", "commands"],
      "properties": {
        "plan_id": { "type": "string" },
        "duration_seconds": { "type": "number", "minimum": 1800 },
        "warmup_seconds": { "type": "number", "minimum": 0 },
        "commands": {
          "type": "array",
          "items": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "measurement_environment": {
      "type": "object",
      "required": ["ambient_c", "cooling", "enclosure", "operator"],
      "properties": {
        "ambient_c": { "type": "number", "minimum": 0, "maximum": 60 },
        "cooling": { "type": "string" },
        "enclosure": { "type": "string" },
        "operator": { "type": "string" }
      }
    },
    "instrumentation": {
      "type": "object",
      "required": ["capture_statuses", "power", "thermal", "frequency"],
      "properties": {
        "capture_statuses": { "type": "object" },
        "power": { "type": "array" },
        "thermal": { "type": "array" },
        "frequency": { "type": "array" }
      }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "power_trace",
        "thermal_trace",
        "frequency_trace",
        "workload_transcript",
        "calibration_record"
      ]
    },
    "computed_metrics": {
      "type": "object"
    },
    "release_blockers": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
