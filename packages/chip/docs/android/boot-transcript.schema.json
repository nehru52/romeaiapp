{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eliza.android_virtual_device_smoke.schema.v1",
  "title": "Eliza Android virtual-device smoke evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "claim_boundary",
    "target",
    "environment",
    "external_tree",
    "commands",
    "start_utc",
    "end_utc",
    "result",
    "boot_claim",
    "compatibility_claim",
    "smoke_log_path",
    "required_markers",
    "forbidden_markers",
    "blockers"
  ],
  "properties": {
    "schema": {
      "const": "eliza.android_virtual_device_smoke.v1"
    },
    "claim_boundary": {
      "const": "virtual_device_smoke_only_not_boot_or_compatibility_evidence"
    },
    "target": {
      "const": "eliza_ai_soc"
    },
    "environment": {
      "enum": ["cuttlefish_riscv64", "qemu_riscv64", "renode_e1_soc"]
    },
    "external_tree": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "start_utc": {
      "type": "string",
      "format": "date-time"
    },
    "end_utc": {
      "type": "string",
      "format": "date-time"
    },
    "result": {
      "enum": ["PASS", "FAIL", "BLOCKED"]
    },
    "boot_claim": {
      "const": "none"
    },
    "compatibility_claim": {
      "const": "none"
    },
    "smoke_log_path": {
      "type": "string",
      "pattern": "^docs/evidence/android/.+\\.log$"
    },
    "required_markers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_markers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "observed_properties": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "hal_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "e1_npu": {
          "enum": ["absent_fail_closed", "present_started", "blocked"]
        },
        "graphics_composer": {
          "enum": ["absent_fail_closed", "present_started", "blocked"]
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
