      "required_all": ["renode", "eliza_ai_soc"],
      "forbidden_any": ["Kernel panic", "Unhandled", "boot timeout", "FAILED"],
      "forbidden_claims": [
        "booted on e1_soc",
        "Android compatible",
        "CTS passed",
        "VTS passed",
        "certified"
      ]
    }
  }
}
