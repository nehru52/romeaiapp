STATUS: BLOCKED — template evidence; replace with captured transcript after qemu/Cuttlefish/board run
# ======================================================================
# Template evidence for the NPU-userspace side of the minimum Linux+NPU
# target. This file documents the marker contract that a real captured
# transcript at `docs/evidence/linux/eliza_e1_npu_ml_smoke.log` must
# satisfy in order for `scripts/check_e1_npu_linux_smoke.py` (and the
# aggregate `make minimum-linux-npu-target-check`) to leave BLOCKED
# status and move toward PASS.
#
# This file is NEVER consumed as a real NPU smoke transcript:
#   - the file name ends in `.template.log` (not the canonical
#     `eliza_e1_npu_ml_smoke.log` that the gate reads), so the script
#     never opens it.
#   - every documented marker line is prefixed with `# REQUIRED_MARKER:`
#     so the literal marker string does NOT appear as a bare line in
#     this template; this prevents accidental gate-pass on the template.
#   - the first line of this file is `STATUS: BLOCKED ...`, which the
#     fail-closed gates treat as evidence that real capture has not yet
#     been performed.
#
# claim_boundary: template_evidence_only_no_silicon_or_qemu_boot_claim
# real_evidence_path: docs/evidence/linux/eliza_e1_npu_ml_smoke.log
# gate: scripts/check_e1_npu_linux_smoke.py
# aggregate_gate: scripts/check_minimum_linux_npu_target.py
# make_target: minimum-linux-npu-target-check
#
# To replace this template with real evidence:
#   1. Build the Eliza-E1 Buildroot image so it includes the
#      `e1-npu-ml-smoke` package:
#        make BR2_EXTERNAL=$PWD/sw/buildroot eliza_e1_defconfig
#        make BR2_EXTERNAL=$PWD/sw/buildroot
#   2. Boot Linux on the generated Eliza Rocket AP (or the qemu-virt /
#      Cuttlefish RV64 reference path) with the e1 NPU MMIO range mapped
#      and the e1-npu char device probed.
#   3. From the target shell, run:
#        /usr/bin/e1-npu-ml-smoke \
#            --device /dev/e1-npu \
#            --workload gemm_s8_int8_2x2x3 \
#            --require-npu
#      The smoke binary prints the runtime contract, executes
#      `E1_NPU_IOC_RUN_GEMM_S8`, hashes the input and output tensors,
#      and emits the marker lines below.
#   4. Capture the full transcript through
#        E1_NPU_ML_SMOKE_CMD='ssh root@TARGET /usr/bin/e1-npu-ml-smoke \
#            --device /dev/e1-npu --workload gemm_s8_int8_2x2x3 \
#            --require-npu' \
#        sw/buildroot/scripts/capture-buildroot-evidence.sh \
#            /path/to/buildroot ml-smoke
#      Write the resulting transcript to
#        docs/evidence/linux/eliza_e1_npu_ml_smoke.log
#      (NOT to this template).
#   5. Re-run `make minimum-linux-npu-target-check`. The gate moves from
#      BLOCKED to PASS only when every required marker below appears in
#      the captured transcript and none of the forbidden patterns
#      (`CPU-only fallback`, `status=FAIL`, `not found`, `No such file`)
#      are present.
# ======================================================================

# --- NPU ML smoke transcript markers --------------------------------
# These markers must appear verbatim in
# docs/evidence/linux/eliza_e1_npu_ml_smoke.log . The order below
# matches the order in which `scripts/check_e1_npu_linux_smoke.py`
# enumerates them.
# REQUIRED_MARKER: eliza-evidence: target=linux artifact=e1_npu_ml_smoke
# REQUIRED_MARKER: COMMAND=
# REQUIRED_MARKER: /usr/bin/e1-npu-ml-smoke
# REQUIRED_MARKER: --workload gemm_s8_int8_2x2x3
# REQUIRED_MARKER: --require-npu
# REQUIRED_MARKER: e1-npu-ml-smoke: PASS
# REQUIRED_MARKER: workload=gemm_s8_int8_2x2x3
# REQUIRED_MARKER: contract_version=1
# REQUIRED_MARKER: desc_bytes_read=
# REQUIRED_MARKER: desc_bytes_written=
# REQUIRED_MARKER: desc_read_beats=
# REQUIRED_MARKER: desc_write_beats=
# REQUIRED_MARKER: desc_timeout_count=
# REQUIRED_MARKER: claim_boundary=driver_ioctl_gemm_only_not_nnapi_or_hardware_benchmark
# REQUIRED_MARKER: eliza-evidence: status=PASS

# --- Minimum transcript size ---------------------------------------
# `check_e1_npu_linux_smoke.py` rejects any transcript smaller than
# 256 bytes as "too small to be a target transcript".
# REQUIRED_MIN_BYTES: 256

# --- Forbidden patterns --------------------------------------------
# These regexes must NOT match in the canonical evidence file. They
# appear here only as anti-patterns; the fail-closed gate treats any
# match as FAIL.
# FORBIDDEN_REGEX: CPU-only fallback
# FORBIDDEN_REGEX: status=FAIL
# FORBIDDEN_REGEX: not found
# FORBIDDEN_REGEX: No such file

# --- Supporting source-side markers --------------------------------
# The same gate also checks that the in-tree NPU userspace smoke
# source, UAPI, driver, DTS, and platform contract still spell the
# IOCTLs and opcodes used above. These checks operate on source files,
# not on the captured transcript, but the captured transcript only
# becomes meaningful when the source side still names:
# REQUIRED_SOURCE_MARKER: E1_NPU_IOC_RUN_GEMM_S8
# REQUIRED_SOURCE_MARKER: E1_NPU_IOC_GET_CONTRACT
# REQUIRED_SOURCE_MARKER: E1_NPU_IOC_GET_COUNTERS
# REQUIRED_SOURCE_MARKER: E1_NPU_IOC_SUBMIT_DESCRIPTORS
# REQUIRED_SOURCE_MARKER: E1_NPU_OP_RELU4_S8
# REQUIRED_SOURCE_MARKER: E1_NPU_OP_VRELU_S8
# REQUIRED_SOURCE_MARKER: E1_NPU_BASE 0x10020000u
# REQUIRED_SOURCE_MARKER: eliza,e1-npu

# End of template. Real captured transcripts replace
# `docs/evidence/linux/eliza_e1_npu_ml_smoke.log`; this template file
# stays in place as the documented marker contract.
