# E1 AVB vbmeta verifier — host KAT/negative test + freestanding riscv64 target.
#
#   make            # build + run the host test (positive + negatives)
#   make host       # build build/avb/test_avb_verify
#   make run        # build then run it (exit non-zero on any wrong decision)
#   make target     # build the freestanding riscv64-unknown-elf object set
#   make clean
#
# Reuses the constant-time crypto primitives in fw/boot-rom/secure (sha256.c,
# ed25519_ct.c) — no crypto is duplicated here. Run `source ../../tools/env.sh`
# first so riscv64-unknown-elf-gcc is on PATH.

AVB_DIR    := $(abspath $(dir $(lastword $(MAKEFILE_LIST))))
CHIP_ROOT  := $(abspath $(AVB_DIR)/../..)
BUILD_DIR  := $(CHIP_ROOT)/build/avb
SECURE_DIR := $(CHIP_ROOT)/fw/boot-rom/secure

HOST_CC    ?= gcc
RISCV_CC   ?= riscv64-unknown-elf-gcc

WARN       := -Wall -Wextra -Werror -Wshadow -Wconversion
HOST_CFLAGS   ?= -std=c11 -O2 $(WARN) -fstack-protector-strong
TARGET_CFLAGS ?= -std=c11 -O2 $(WARN) -ffreestanding -fno-builtin \
                 -march=rv64imac_zicsr -mabi=lp64 -mcmodel=medany

# Library sources (no main): the verifier plus the shared crypto primitives.
LIB_SRCS := $(AVB_DIR)/avb_verify.c $(SECURE_DIR)/sha256.c \
            $(SECURE_DIR)/ed25519_ct.c
TEST_SRC := $(AVB_DIR)/tests/test_kat.c

# A/B slot + OTA apply logic, layered on the verifier.
AB_LIB_SRCS := $(AVB_DIR)/ab_slot.c $(AVB_DIR)/ota_apply.c
AB_TEST_SRC := $(AVB_DIR)/tests/test_ab_ota.c

HOST_BIN := $(BUILD_DIR)/test_avb_verify
ABOTA_BIN := $(BUILD_DIR)/test_ab_ota
TARGET_OBJS := $(BUILD_DIR)/avb_verify.rv64.o $(BUILD_DIR)/sha256.rv64.o \
               $(BUILD_DIR)/ed25519_ct.rv64.o
AB_TARGET_OBJS := $(BUILD_DIR)/ab_slot.rv64.o $(BUILD_DIR)/ota_apply.rv64.o

INCLUDES := -I$(AVB_DIR) -I$(SECURE_DIR) -I$(BUILD_DIR)

.PHONY: all host run target clean vectors ab-vectors host-abota run-abota \
        target-abota

all: run run-abota

# The expected.h header and test vectors are generated by make_vbmeta.py.
vectors:
	@mkdir -p $(BUILD_DIR)
	python3 $(AVB_DIR)/tests/make_vbmeta.py $(BUILD_DIR)

# A/B + OTA test images and ab_expected.h (reuses the make_vbmeta builder).
ab-vectors:
	@mkdir -p $(BUILD_DIR)
	python3 $(AVB_DIR)/tests/make_ab_images.py $(BUILD_DIR)

host: vectors $(HOST_BIN)

$(HOST_BIN): $(LIB_SRCS) $(TEST_SRC) $(AVB_DIR)/avb_verify.h | vectors
	@mkdir -p $(BUILD_DIR)
	$(HOST_CC) $(HOST_CFLAGS) $(INCLUDES) \
	    $(LIB_SRCS) $(TEST_SRC) -o $@

run: host
	$(HOST_BIN) $(BUILD_DIR)

host-abota: ab-vectors $(ABOTA_BIN)

$(ABOTA_BIN): $(LIB_SRCS) $(AB_LIB_SRCS) $(AB_TEST_SRC) \
              $(AVB_DIR)/ab_slot.h $(AVB_DIR)/ota_apply.h | ab-vectors
	@mkdir -p $(BUILD_DIR)
	$(HOST_CC) $(HOST_CFLAGS) $(INCLUDES) \
	    $(LIB_SRCS) $(AB_LIB_SRCS) $(AB_TEST_SRC) -o $@

run-abota: host-abota
	$(ABOTA_BIN) $(BUILD_DIR)

# Prove the verifier and the A/B/OTA logic compile freestanding for the RoT
# target. The boot ROM links its own crt/startup; here we only assert the
# translation units build.
target: $(TARGET_OBJS) $(AB_TARGET_OBJS)

target-abota: $(AB_TARGET_OBJS)

$(BUILD_DIR)/avb_verify.rv64.o: $(AVB_DIR)/avb_verify.c $(AVB_DIR)/avb_verify.h
	@mkdir -p $(BUILD_DIR)
	$(RISCV_CC) $(TARGET_CFLAGS) -I$(AVB_DIR) -I$(SECURE_DIR) -c $< -o $@

$(BUILD_DIR)/ab_slot.rv64.o: $(AVB_DIR)/ab_slot.c $(AVB_DIR)/ab_slot.h \
                             $(AVB_DIR)/avb_verify.h
	@mkdir -p $(BUILD_DIR)
	$(RISCV_CC) $(TARGET_CFLAGS) -I$(AVB_DIR) -I$(SECURE_DIR) -c $< -o $@

$(BUILD_DIR)/ota_apply.rv64.o: $(AVB_DIR)/ota_apply.c $(AVB_DIR)/ota_apply.h \
                               $(AVB_DIR)/ab_slot.h $(AVB_DIR)/avb_verify.h
	@mkdir -p $(BUILD_DIR)
	$(RISCV_CC) $(TARGET_CFLAGS) -I$(AVB_DIR) -I$(SECURE_DIR) -c $< -o $@

$(BUILD_DIR)/sha256.rv64.o: $(SECURE_DIR)/sha256.c $(SECURE_DIR)/sha256.h
	@mkdir -p $(BUILD_DIR)
	$(RISCV_CC) $(TARGET_CFLAGS) -I$(AVB_DIR) -I$(SECURE_DIR) -c $< -o $@

$(BUILD_DIR)/ed25519_ct.rv64.o: $(SECURE_DIR)/ed25519_ct.c $(SECURE_DIR)/ed25519_ct.h
	@mkdir -p $(BUILD_DIR)
	$(RISCV_CC) $(TARGET_CFLAGS) -I$(AVB_DIR) -I$(SECURE_DIR) -c $< -o $@

clean:
	rm -f $(HOST_BIN) $(ABOTA_BIN) $(TARGET_OBJS) $(AB_TARGET_OBJS) \
	    $(BUILD_DIR)/expected.h $(BUILD_DIR)/ab_expected.h \
	    $(BUILD_DIR)/*.bin
