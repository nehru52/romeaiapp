# Build / TS artifacts
dist/
.turbo/
*.tsbuildinfo

# Python build artifacts
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
*.so

# Generated / training output.
# Ignore every checkpoint subdirectory by default, but keep the tiny
# smoke-test validator checkpoint that ships in-repo (see
# `checkpoints/_validator/README.md`).
/checkpoints/*
!/checkpoints/.gitkeep
!/checkpoints/README.md
!/checkpoints/_validator/
!/checkpoints/_validator/**
out/
wandb/
generated/
results/
reports/*.html

# Media (use object storage instead)
videos/
*.mp4
*.gif
*.webm

# Per-machine captures + calibration
calibration_data/
trajectories.db

# Datasets — keep the schema, never the bytes
data/raw/
data/processed/

# Heavy scene exports
*.usd

# Large numpy arrays. Note: gitignore cannot enforce size; the
# scripts/check-no-large-binaries.sh CI gate rejects any tracked file
# over 5 MB outside the known-source URDF/STL/MJCF asset directories.
*.npz

# OS noise
.DS_Store
research/

# Third-party MJCF source library (sparse-cloned by
# scripts/sync_menagerie.sh; the canonical copies live under
# assets/profiles/<id>/mjcf/ so the menagerie checkout is build-time only).
vendor/mujoco_menagerie/
