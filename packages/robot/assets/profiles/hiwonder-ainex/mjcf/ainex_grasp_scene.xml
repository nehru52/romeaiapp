<mujoco model="ainex_grasp_scene">
  <!-- Extends ainex_primitives.xml with graspable object and target site for manipulation tasks.
       Used by grasp.py, carry.py, and place.py environments. -->

  <include file="ainex_primitives.xml"/>

  <default>
    <default class="graspable">
      <geom mass="0.05" type="box" size="0.03 0.03 0.03"
            contype="1" conaffinity="1"
            friction="1.0 0.02 0.01"
            solimp="0.95 0.99 0.001" solref="0.004 1"
            rgba="0.2 0.8 0.2 1"/>
    </default>
    <default class="target_zone">
      <site type="cylinder" size="0.08 0.001" rgba="0.2 0.2 0.9 0.4" group="3"/>
    </default>
  </default>

  <worldbody>
    <!-- Graspable object: small cube, 0.05kg, 3cm per side -->
    <body name="grasp_object" pos="0.3 0 0.03">
      <freejoint name="object_joint"/>
      <inertial pos="0 0 0" mass="0.05"
                fullinertia="3e-05 3e-05 3e-05 0 0 0"/>
      <geom name="object_geom" class="graspable"/>
      <site name="object_site" pos="0 0 0" size="0.005" group="5"/>
    </body>

    <!-- Target placement zone (visual only, no collision) -->
    <site name="target_zone" class="target_zone" pos="1.0 0 0.001"/>
  </worldbody>

  <!-- Contact: object must collide with floor and gripper geoms -->
  <contact>
    <pair geom1="object_geom" geom2="floor" condim="4"
          friction="0.8 0.8 0.005 0.0001 0.0001"/>
    <pair geom1="object_geom" geom2="r_foot1" condim="4"/>
    <pair geom1="object_geom" geom2="r_foot2" condim="4"/>
    <pair geom1="object_geom" geom2="l_foot1" condim="4"/>
    <pair geom1="object_geom" geom2="l_foot2" condim="4"/>
  </contact>

  <!-- Weld equality constraint for place.py: disabled by default, activated
       when the object should start attached to the gripper. -->
  <equality>
    <weld name="object_weld" body1="r_gripper_link" body2="grasp_object"
          relpose="0 -0.02 -0.01 1 0 0 0" active="false"/>
  </equality>

  <!-- Sensor: contact between gripper geoms and the graspable object -->
  <sensor>
    <touch name="r_gripper_object_touch" site="object_site"/>
  </sensor>

</mujoco>
