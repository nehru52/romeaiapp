<mujoco model="ainex">
  <compiler angle="radian" meshdir="../meshes/"
            autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" solver="Newton" iterations="100" tolerance="1e-10"
          integrator="implicitfast" cone="elliptic">
    <flag warmstart="enable" contact="enable"/>
  </option>

  <default>
    <joint limited="true" damping="5.0" armature="0.04" frictionloss="0.1"
           range="-1.57 1.57"/>
    <geom contype="0" conaffinity="0" condim="3" friction="0.7 0.1 0.001"
          rgba="0.3 0.3 0.35 1" type="mesh"/>
    <motor ctrllimited="true" ctrlrange="-6 6"/>
    <position kp="50" kv="5"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.4 0.6 0.8" rgb2="0.1 0.1 0.2" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.35 0.4 0.45" rgb2="0.4 0.45 0.5"
             width="512" height="512" mark="edge" markrgb="0.5 0.55 0.6"/>
    <material name="grid" texture="grid" texrepeat="8 8" texuniform="true" reflectance="0.3"/>
    <material name="robot_dark" rgba="0.25 0.25 0.28 1" specular="0.4" shininess="0.5"/>
    <material name="robot_accent" rgba="0.3 0.5 0.9 1" specular="0.5" shininess="0.7"/>
    <material name="foot" rgba="0.3 0.3 0.3 1" specular="0.2" shininess="0.3"/>
    <material name="ball_red" rgba="0.9 0.15 0.15 1" specular="0.8" shininess="0.9"/>

    <!-- Robot meshes -->
    <mesh name="body_link" file="body_link.STL" scale="1 1 1"/>
    <mesh name="r_hip_yaw_link" file="r_hip_yaw_link.STL"/>
    <mesh name="r_hip_roll_link" file="r_hip_roll_link.STL"/>
    <mesh name="r_hip_pitch_link" file="r_hip_pitch_link.STL"/>
    <mesh name="r_knee_link" file="r_knee_link.STL"/>
    <mesh name="r_ank_pitch_link" file="r_ank_pitch_link.STL"/>
    <mesh name="r_ank_roll_link" file="r_ank_roll_link.STL"/>
    <mesh name="l_hip_yaw_link" file="l_hip_yaw_link.STL"/>
    <mesh name="l_hip_roll_link" file="l_hip_roll_link.STL"/>
    <mesh name="l_hip_pitch_link" file="l_hip_pitch_link.STL"/>
    <mesh name="l_knee_link" file="l_knee_link.STL"/>
    <mesh name="l_ank_pitch_link" file="l_ank_pitch_link.STL"/>
    <mesh name="l_ank_roll_link" file="l_ank_roll_link.STL"/>
    <mesh name="head_pan_link" file="head_pan_link.STL"/>
    <mesh name="head_tilt_link" file="head_tilt_link.STL"/>
    <mesh name="r_sho_pitch_link" file="r_sho_pitch_link.STL"/>
    <mesh name="r_sho_roll_link" file="r_sho_roll_link.STL"/>
    <mesh name="r_el_pitch_link" file="r_el_pitch_link.STL"/>
    <mesh name="r_el_yaw_link" file="r_el_yaw_link.STL"/>
    <mesh name="r_gripper_link" file="r_gripper_link.STL"/>
    <mesh name="l_sho_pitch_link" file="l_sho_pitch_link.STL"/>
    <mesh name="l_sho_roll_link" file="l_sho_roll_link.STL"/>
    <mesh name="l_el_pitch_link" file="l_el_pitch_link.STL"/>
    <mesh name="l_el_yaw_link" file="l_el_yaw_link.STL"/>
    <mesh name="l_gripper_link" file="l_gripper_link.STL"/>
  </asset>

  <worldbody>
    <!-- Ground -->
    <geom name="floor" type="plane" size="5 5 0.1" material="grid" conaffinity="1" contype="1"/>

    <!-- Lighting -->
    <light name="top" pos="0 0 3" dir="0 0 -1" diffuse="1.0 1.0 1.0" specular="0.5 0.5 0.5"/>
    <light name="front" pos="2 -2 3" dir="-0.5 0.5 -1" diffuse="0.7 0.7 0.7" specular="0.3 0.3 0.3"/>
    <light name="fill" pos="-1 2 2" dir="0.3 -0.5 -0.7" diffuse="0.4 0.4 0.5"/>

    <!-- Target ball -->
    <body name="target_ball" pos="0.5 0 0.04">
      <geom name="ball" type="sphere" size="0.04" material="ball_red" mass="0.05"
            contype="1" conaffinity="1"/>
      <joint name="ball_x" type="slide" axis="1 0 0" limited="false" damping="0"/>
      <joint name="ball_y" type="slide" axis="0 1 0" limited="false" damping="0"/>
      <joint name="ball_z" type="slide" axis="0 0 1" limited="false" damping="0"/>
    </body>

    <!-- Robot -->
    <body name="base_link" pos="0 0 0.28" euler="0 0 0">
      <freejoint name="root"/>

      <!-- Body (torso) -->
      <body name="body_link">
        <inertial pos="0.00394 -0.0000793 0.05045" mass="0.743"
                  fullinertia="0.00121619 0.00104402 0.00108564 2.48e-06 -5.348e-05 -2e-06"/>
        <geom name="body" mesh="body_link" material="robot_dark"/>
        <site name="imu" pos="0 0 0.05" size="0.005" rgba="0 1 0 0.5"/>

        <!-- ==================== RIGHT LEG ==================== -->
        <body name="r_hip_yaw_link" pos="0 -0.029 0">
          <joint name="r_hip_yaw" axis="0 0 -1"/>
          <inertial pos="-0.0000308 0.001257 -0.001371" mass="0.032"
                    fullinertia="1.756e-05 2.27e-05 9.05e-06 -2.8e-07 -3.3e-07 9.2e-07"/>
          <geom mesh="r_hip_yaw_link" material="robot_dark"/>

          <body name="r_hip_roll_link" pos="-0.01955 0 -0.0255">
            <joint name="r_hip_roll" axis="-1 0 0"/>
            <inertial pos="0.001362 -0.000567 -0.01342" mass="0.120"
                      fullinertia="2.918e-05 7.31e-05 6.05e-05 -9e-07 -4.5e-07 0.0"/>
            <geom mesh="r_hip_roll_link" material="robot_dark"/>

            <body name="r_hip_pitch_link" pos="0.01904 -0.02 0">
              <joint name="r_hip_pitch" axis="0 -1 0"/>
              <inertial pos="0.01359 0.01938 -0.07271" mass="0.1065"
                        fullinertia="0.00011009 0.00011292 4.163e-05 2.5e-07 -8.22e-06 5.8e-07"/>
              <geom mesh="r_hip_pitch_link" material="robot_dark"/>

              <body name="r_knee_link" pos="-0.000372 0.00005 -0.09689">
                <joint name="r_knee" axis="0 -1 0"/>
                <inertial pos="0.003343 0.01965 -0.04250" mass="0.045"
                          fullinertia="6.733e-05 5.5e-05 2.073e-05 5e-08 2.85e-06 0.0"/>
                <geom mesh="r_knee_link" material="robot_dark"/>

                <body name="r_ank_pitch_link" pos="0.001037 0 -0.08908">
                  <joint name="r_ank_pitch" axis="0 1 0"/>
                  <inertial pos="-0.01754 0.01956 0.01342" mass="0.120"
                            fullinertia="2.92e-05 7.365e-05 6.107e-05 -1.22e-06 4.7e-07 2e-08"/>
                  <geom mesh="r_ank_pitch_link" material="robot_dark"/>

                  <body name="r_ank_roll_link" pos="-0.01904 0.02 0">
                    <joint name="r_ank_roll" axis="1 0 0"/>
                    <inertial pos="0.02851 -0.01287 -0.01767" mass="0.0675"
                              fullinertia="4.217e-05 9.246e-05 0.00012567 -1.08e-06 -2.26e-06 3.04e-06"/>
                    <geom mesh="r_ank_roll_link" material="foot"
                          friction="1.5 0.5 0.01" contype="0" conaffinity="0"
                          solimp="0.95 0.99 0.001" solref="0.004 1"/>
                    <site name="right_foot" pos="0.02 0 -0.02" size="0.005" rgba="1 0 0 0.5"/>
                    <geom name="r_foot1" type="box" size="0.04 0.025 0.005"
                          pos="0.02 0 -0.025" rgba="0.3 0.3 0.3 0"
                          friction="1.5 0.5 0.01" contype="1" conaffinity="1"/>
                    <geom name="r_foot2" type="box" size="0.02 0.025 0.005"
                          pos="-0.01 0 -0.025" rgba="0.3 0.3 0.3 0"
                          friction="1.5 0.5 0.01" contype="1" conaffinity="1"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>

        <!-- ==================== LEFT LEG ==================== -->
        <body name="l_hip_yaw_link" pos="0 0.029 0">
          <joint name="l_hip_yaw" axis="0 0 -1"/>
          <inertial pos="-0.0000311 -0.001257 -0.001371" mass="0.032"
                    fullinertia="1.756e-05 2.27e-05 9.05e-06 2.88e-07 -3.3e-07 -9.2e-07"/>
          <geom mesh="l_hip_yaw_link" material="robot_dark"/>

          <body name="l_hip_roll_link" pos="-0.01955 0 -0.0255">
            <joint name="l_hip_roll" axis="-1 0 0"/>
            <inertial pos="0.001362 0.000567 -0.01342" mass="0.120"
                      fullinertia="2.918e-05 7.31e-05 6.05e-05 9e-07 -4.5e-07 0.0"/>
            <geom mesh="l_hip_roll_link" material="robot_dark"/>

            <body name="l_hip_pitch_link" pos="0.019037 0.02 0">
              <joint name="l_hip_pitch" axis="0 1 0"/>
              <inertial pos="0.01359 -0.01938 -0.07271" mass="0.1065"
                        fullinertia="0.00011009 0.00011292 4.163e-05 -2.5e-07 -8.22e-06 -5.8e-07"/>
              <geom mesh="l_hip_pitch_link" material="robot_dark"/>

              <body name="l_knee_link" pos="-0.00037204 -0.00005 -0.096886">
                <joint name="l_knee" axis="0 1 0"/>
                <inertial pos="0.003343 -0.01965 -0.04251" mass="0.045"
                          fullinertia="6.733e-05 5.5e-05 2.073e-05 -4e-08 2.85e-06 0.0"/>
                <geom mesh="l_knee_link" material="robot_dark"/>

                <body name="l_ank_pitch_link" pos="0.001037 0 -0.089077">
                  <joint name="l_ank_pitch" axis="0 -1 0"/>
                  <inertial pos="-0.01754 -0.01956 0.01342" mass="0.120"
                            fullinertia="2.92e-05 7.365e-05 6.107e-05 1.22e-06 4.7e-07 -2e-08"/>
                  <geom mesh="l_ank_pitch_link" material="robot_dark"/>

                  <body name="l_ank_roll_link" pos="-0.019037 -0.02 0">
                    <joint name="l_ank_roll" axis="1 0 0"/>
                    <inertial pos="0.02851 0.01287 -0.01767" mass="0.0675"
                              fullinertia="4.217e-05 9.246e-05 0.00012567 1.08e-06 -2.26e-06 -3.04e-06"/>
                    <geom mesh="l_ank_roll_link" material="foot"
                          friction="1.5 0.5 0.01" contype="0" conaffinity="0"
                          solimp="0.95 0.99 0.001" solref="0.004 1"/>
                    <site name="left_foot" pos="0.02 0 -0.02" size="0.005" rgba="1 0 0 0.5"/>
                    <geom name="l_foot1" type="box" size="0.04 0.025 0.005"
                          pos="0.02 0 -0.025" rgba="0.3 0.3 0.3 0"
                          friction="1.5 0.5 0.01" contype="1" conaffinity="1"/>
                    <geom name="l_foot2" type="box" size="0.02 0.025 0.005"
                          pos="-0.01 0 -0.025" rgba="0.3 0.3 0.3 0"
                          friction="1.5 0.5 0.01" contype="1" conaffinity="1"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>

        <!-- ==================== HEAD ==================== -->
        <body name="head_pan_link" pos="-0.00410 0 0.10780">
          <joint name="head_pan" axis="0 0 -1"/>
          <inertial pos="0.00549 0.000157 0.01413" mass="0.00767"
                    fullinertia="2.12e-06 9.87e-07 1.84e-06 0.0 -1.44e-07 0.0"/>
          <geom mesh="head_pan_link" material="robot_accent"/>

          <body name="head_tilt_link" pos="0.00905 -0.01857 0.02816">
            <joint name="head_tilt" axis="0 -1 0"/>
            <inertial pos="0.01134 0.01892 0.02212" mass="0.02622"
                      fullinertia="6.2e-06 6.32e-06 6.9e-06 1e-08 8e-07 -2e-08"/>
            <geom mesh="head_tilt_link" material="robot_accent"/>

            <!-- Camera site for rendering -->
            <site name="camera_eye" pos="0.03 0 0.01" euler="0 0 0" size="0.005"/>
            <camera name="head_cam" pos="0.03 0 0.01" fovy="49.1" mode="fixed"/>
          </body>
        </body>

        <!-- ==================== RIGHT ARM ==================== -->
        <body name="r_sho_pitch_link" pos="-0.0000547 -0.05249 0.08745">
          <joint name="r_sho_pitch" axis="0 -1 0" damping="3.0" armature="0.08" frictionloss="0.2"/>
          <inertial pos="0.000376 -0.01133 0.0000021" mass="0.0128"
                    fullinertia="2.05e-06 3.9e-06 5.03e-06 -5e-08 0.0 0.0"/>
          <geom mesh="r_sho_pitch_link" material="robot_dark"/>

          <body name="r_sho_roll_link" pos="0.020003 -0.02151 0">
            <joint name="r_sho_roll" axis="1 0 0" damping="3.0" armature="0.08" frictionloss="0.2"/>
            <inertial pos="-0.02050 -0.02784 -0.0000611" mass="0.121"
                      fullinertia="7.3e-05 2.527e-05 7.539e-05 8.68e-06 -5e-08 -1.8e-07"/>
            <geom mesh="r_sho_roll_link" material="robot_dark"/>

            <body name="r_el_pitch_link" pos="-0.020003 -0.07411 0">
              <joint name="r_el_pitch" axis="0 -1 0" damping="3.0" armature="0.08" frictionloss="0.2"/>
              <inertial pos="-0.006976 -0.01290 0.000205" mass="0.045"
                        fullinertia="7.97e-06 8.3e-06 1.053e-05 6.5e-07 -1.5e-07 -5e-08"/>
              <geom mesh="r_el_pitch_link" material="robot_dark"/>

              <body name="r_el_yaw_link" pos="0.000398 -0.01702 0.01907">
                <joint name="r_el_yaw" axis="0 0 1" damping="3.0" armature="0.08" frictionloss="0.2"/>
                <inertial pos="-0.000229 -0.05727 -0.01387" mass="0.102"
                          fullinertia="0.0001432 3.101e-05 0.00014052 3e-07 -3e-08 -1.329e-05"/>
                <geom mesh="r_el_yaw_link" material="robot_dark"/>

                <body name="r_gripper_link" pos="0.01989 -0.08924 -0.01907">
                  <joint name="r_gripper" axis="1 0 0" damping="3.0" armature="0.08" frictionloss="0.2"/>
                  <inertial pos="-0.01939 -0.00931 -0.00543" mass="0.0135"
                            fullinertia="3.28e-06 4.51e-06 5.97e-06 -3e-08 -2e-08 1.05e-06"/>
                  <geom mesh="r_gripper_link" material="robot_dark"/>
                </body>
              </body>
            </body>
          </body>
        </body>

        <!-- ==================== LEFT ARM ==================== -->
        <body name="l_sho_pitch_link" pos="-0.0000547 0.052491 0.087448">
          <joint name="l_sho_pitch" axis="0 -1 0" damping="3.0" armature="0.08" frictionloss="0.2"/>
          <inertial pos="0.000376 0.01133 0.0000020" mass="0.0128"
                    fullinertia="2.05e-06 3.9e-06 5.03e-06 5e-08 0.0 0.0"/>
          <geom mesh="l_sho_pitch_link" material="robot_dark"/>

          <body name="l_sho_roll_link" pos="0.020003 0.021507 0">
            <joint name="l_sho_roll" axis="1 0 0" damping="3.0" armature="0.08" frictionloss="0.2"/>
            <inertial pos="-0.020504 0.027838 -0.0000604" mass="0.121"
                      fullinertia="7.3e-05 2.527e-05 7.539e-05 -8.68e-06 -5e-08 1.8e-07"/>
            <geom mesh="l_sho_roll_link" material="robot_dark"/>

            <body name="l_el_pitch_link" pos="-0.020003 0.074109 0">
              <joint name="l_el_pitch" axis="0 -1 0" damping="3.0" armature="0.08" frictionloss="0.2"/>
              <inertial pos="-0.006976 0.012896 0.000207" mass="0.045"
                        fullinertia="7.97e-06 8.3e-06 1.053e-05 -6.5e-07 -1.5e-07 5e-08"/>
              <geom mesh="l_el_pitch_link" material="robot_dark"/>

              <body name="l_el_yaw_link" pos="0.000395 0.017019 0.019072">
                <joint name="l_el_yaw" axis="0 0 1" damping="3.0" armature="0.08" frictionloss="0.2"/>
                <inertial pos="-0.000226 0.057271 -0.013870" mass="0.102"
                          fullinertia="0.0001432 3.101e-05 0.00014052 -3e-07 -3e-08 1.329e-05"/>
                <geom mesh="l_el_yaw_link" material="robot_dark"/>

                <body name="l_gripper_link" pos="0.019893 0.089232 -0.019072">
                  <joint name="l_gripper" axis="1 0 0" damping="3.0" armature="0.08" frictionloss="0.2"/>
                  <inertial pos="-0.019384 0.009314 -0.005426" mass="0.0135"
                            fullinertia="3.28e-06 4.51e-06 5.97e-06 3e-08 -2e-08 -1.05e-06"/>
                  <geom mesh="l_gripper_link" material="robot_dark"/>
                </body>
              </body>
            </body>
          </body>
        </body>

      </body><!-- /body_link -->
    </body><!-- /base_link -->
  </worldbody>

  <!-- Exclude adjacent-link self-collision -->
  <contact>
    <exclude body1="body_link" body2="r_hip_yaw_link"/>
    <exclude body1="body_link" body2="l_hip_yaw_link"/>
    <exclude body1="body_link" body2="head_pan_link"/>
    <exclude body1="body_link" body2="r_sho_pitch_link"/>
    <exclude body1="body_link" body2="l_sho_pitch_link"/>
    <exclude body1="r_hip_yaw_link" body2="r_hip_roll_link"/>
    <exclude body1="r_hip_roll_link" body2="r_hip_pitch_link"/>
    <exclude body1="r_hip_pitch_link" body2="r_knee_link"/>
    <exclude body1="r_knee_link" body2="r_ank_pitch_link"/>
    <exclude body1="r_ank_pitch_link" body2="r_ank_roll_link"/>
    <exclude body1="l_hip_yaw_link" body2="l_hip_roll_link"/>
    <exclude body1="l_hip_roll_link" body2="l_hip_pitch_link"/>
    <exclude body1="l_hip_pitch_link" body2="l_knee_link"/>
    <exclude body1="l_knee_link" body2="l_ank_pitch_link"/>
    <exclude body1="l_ank_pitch_link" body2="l_ank_roll_link"/>
    <exclude body1="head_pan_link" body2="head_tilt_link"/>
    <exclude body1="r_sho_pitch_link" body2="r_sho_roll_link"/>
    <exclude body1="r_sho_roll_link" body2="r_el_pitch_link"/>
    <exclude body1="r_el_pitch_link" body2="r_el_yaw_link"/>
    <exclude body1="r_el_yaw_link" body2="r_gripper_link"/>
    <exclude body1="l_sho_pitch_link" body2="l_sho_roll_link"/>
    <exclude body1="l_sho_roll_link" body2="l_el_pitch_link"/>
    <exclude body1="l_el_pitch_link" body2="l_el_yaw_link"/>
    <exclude body1="l_el_yaw_link" body2="l_gripper_link"/>
  </contact>

  <!-- Position-controlled actuators for all 24 joints -->
  <actuator>
    <!-- Legs (position control, stiff servos) -->
    <position name="r_hip_yaw_act"   joint="r_hip_yaw"   kp="50" kv="5"/>
    <position name="r_hip_roll_act"  joint="r_hip_roll"  kp="50" kv="5"/>
    <position name="r_hip_pitch_act" joint="r_hip_pitch" kp="50" kv="5"/>
    <position name="r_knee_act"      joint="r_knee"      kp="50" kv="5"/>
    <position name="r_ank_pitch_act" joint="r_ank_pitch" kp="50" kv="5"/>
    <position name="r_ank_roll_act"  joint="r_ank_roll"  kp="50" kv="5"/>

    <position name="l_hip_yaw_act"   joint="l_hip_yaw"   kp="50" kv="5"/>
    <position name="l_hip_roll_act"  joint="l_hip_roll"  kp="50" kv="5"/>
    <position name="l_hip_pitch_act" joint="l_hip_pitch" kp="50" kv="5"/>
    <position name="l_knee_act"      joint="l_knee"      kp="50" kv="5"/>
    <position name="l_ank_pitch_act" joint="l_ank_pitch" kp="50" kv="5"/>
    <position name="l_ank_roll_act"  joint="l_ank_roll"  kp="50" kv="5"/>

    <!-- Head (softer servos) -->
    <position name="head_pan_act"  joint="head_pan"  kp="10" kv="1"/>
    <position name="head_tilt_act" joint="head_tilt" kp="10" kv="1"/>

    <!-- Arms (soft servos) -->
    <position name="r_sho_pitch_act" joint="r_sho_pitch" kp="10" kv="1"/>
    <position name="r_sho_roll_act"  joint="r_sho_roll"  kp="10" kv="1"/>
    <position name="r_el_pitch_act"  joint="r_el_pitch"  kp="10" kv="1"/>
    <position name="r_el_yaw_act"    joint="r_el_yaw"    kp="10" kv="1"/>
    <position name="r_gripper_act"   joint="r_gripper"   kp="10" kv="1"/>

    <position name="l_sho_pitch_act" joint="l_sho_pitch" kp="10" kv="1"/>
    <position name="l_sho_roll_act"  joint="l_sho_roll"  kp="10" kv="1"/>
    <position name="l_el_pitch_act"  joint="l_el_pitch"  kp="10" kv="1"/>
    <position name="l_el_yaw_act"    joint="l_el_yaw"    kp="10" kv="1"/>
    <position name="l_gripper_act"   joint="l_gripper"   kp="10" kv="1"/>
  </actuator>

  <!-- Sensors (following MuJoCo Playground OP3 pattern) -->
  <sensor>
    <!-- IMU sensors on torso -->
    <accelerometer name="accelerometer" site="imu"/>
    <gyro name="gyro" site="imu"/>
    <framezaxis name="upvector" objtype="site" objname="imu"/>

    <!-- Velocity sensors -->
    <framelinvel name="global_linvel" objtype="site" objname="imu"/>
    <frameangvel name="global_angvel" objtype="site" objname="imu"/>
    <velocimeter name="local_linvel" site="imu"/>

    <!-- Body state -->
    <framequat name="body_quat" objtype="body" objname="body_link"/>
    <subtreecom name="com" body="base_link"/>

    <!-- Foot velocity sensors -->
    <framelinvel name="left_foot_global_linvel" objtype="site" objname="left_foot"/>
    <framelinvel name="right_foot_global_linvel" objtype="site" objname="right_foot"/>

    <!-- Foot contact sensors (contact pair for floor detection) -->
    <contact name="l_foot1_floor_found" geom1="l_foot1" geom2="floor" reduce="mindist" num="1" data="found"/>
    <contact name="l_foot2_floor_found" geom1="l_foot2" geom2="floor" reduce="mindist" num="1" data="found"/>
    <contact name="r_foot1_floor_found" geom1="r_foot1" geom2="floor" reduce="mindist" num="1" data="found"/>
    <contact name="r_foot2_floor_found" geom1="r_foot2" geom2="floor" reduce="mindist" num="1" data="found"/>
  </sensor>

  <!-- Keyframes for initial poses -->
  <keyframe>
    <!-- Standing straight (legs at zero, arms tucked) -->
    <!-- qpos order: root(7) + joints in body order -->
    <!-- root: x y z qw qx qy qz = 0 0 0.24 1 0 0 0 -->
