    <!-- qpos order: ball_x ball_y ball_z (3) | root_x root_y root_z root_qw root_qx root_qy root_qz (7) | joints (24) -->
    <key name="stand"
         qpos="0.5 0 0.04
               0 0 0.24 1 0 0 0
