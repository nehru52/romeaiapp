{
  "name": "@elizaos/robot",
  "version": "2.0.3-beta.0",
  "description": "Python robotics stack (MuJoCo sim, Alberta continual-RL training, Brax/MJX baselines, websocket bridge, perception, trajectory DB) with a thin TS surface for re-exports and shared schemas. Drives simulated and real robots via profile-driven configuration; first profile is Hiwonder AiNex.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageType": "library",
  "platform": "node",
  "license": "MIT",
  "author": "elizaOS",
  "keywords": [
    "elizaos",
    "robotics",
    "mujoco",
    "brax",
    "rl",
    "ainex",
    "hiwonder"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/eliza"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "build.config.ts"
  ],
  "scripts": {
    "build": "tsdown --config build.config.ts",
    "clean": "rm -rf dist .turbo",
    "lint": "bunx @biomejs/biome check --write ./src",
    "lint:check": "bunx @biomejs/biome check ./src",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run && bun run test:py",
    "test:py": "uv run pytest tests/ -q || python -m pytest tests/ -q",
    "format": "bunx @biomejs/biome format --write ./src",
    "format:check": "bunx @biomejs/biome format ./src",
    "robot:bridge:mock": "uv run python -m eliza_robot.bridge.server --backend mock --port 9100",
    "robot:bridge:mujoco": "uv run python -m eliza_robot.bridge.server --backend mujoco --port 9100",
    "robot:demo": "bash examples/robot-mujoco-demo/run.sh"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "unrun": "^0.3.0",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "eliza": {
    "platforms": [
      "node"
    ],
    "runtime": "node",
    "platformDetails": {
      "node": "Node.js TS surface; heavy logic lives in the Python sidecar (eliza-robot)."
    }
  }
}
