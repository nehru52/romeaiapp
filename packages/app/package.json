    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "@fontsource/poppins": "^5.2.7",
    "@pixiv/three-vrm": "^3.4.5",
    "llama-cpp-capacitor": "^0.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "adze": "^2.3.0",
    "bun-types": "^1.3.12",
    "jsdom": "^29.0.0",
    "json5": "^2.2.3",
    "pathe": "^2.0.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "ws": "^8.18.3",
    "yaml": "^2.9.0"
  },
  "private": true
}
