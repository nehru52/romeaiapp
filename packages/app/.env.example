# CDN base URL for static binary assets (VRMs, splash backgrounds).
# Defaults to the Cloudflare R2 public domain when not set.
# Set to https://blob.elizacloud.ai for production or a custom CDN domain.
VITE_ASSET_BASE_URL=https://blob.elizacloud.ai

# Feature flags
VITE_ENABLE_COMPANION_MODE=

# iOS runtime modes:
# - cloud: use bundled web assets and Eliza Cloud
# - remote-mac: connect the phone build to a Mac-hosted Eliza API
# - cloud-hybrid: use cloud runtime and connect the device bridge for local compute
VITE_ELIZA_IOS_RUNTIME_MODE=
VITE_ELIZA_CLOUD_BASE=https://www.elizacloud.ai
VITE_ELIZA_IOS_API_BASE=
# Build-time API tokens are embedded in the web bundle. Use only for dev
# builds or short-lived test credentials.
VITE_ELIZA_IOS_API_TOKEN=
VITE_ELIZA_DEVICE_BRIDGE_URL=
VITE_ELIZA_DEVICE_BRIDGE_TOKEN=

# Swarm/orchestrator runtime env vars (PARALLAX_*, GitHub auth, provider keys)
# are documented in the repository root .env.example:
# ../../.env.example
