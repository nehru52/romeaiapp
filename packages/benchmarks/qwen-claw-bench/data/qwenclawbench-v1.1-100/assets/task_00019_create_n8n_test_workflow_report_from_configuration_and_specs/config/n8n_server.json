{
  "host": "0.0.0.0",
  "port": 5678,
  "protocol": "http",
  "workflowsDir": "/opt/n8n/workflows",
  "executions": {
    "mode": "regular",
    "timeout": 3600,
    "maxTimeout": 7200,
    "saveDataOnError": "all",
    "saveDataOnSuccess": "all",
    "saveDataManualExecutions": true
  },
  "timezone": "UTC",
  "genericTimezone": "America/New_York",
  "version": "1.52.0",
  "database": {
    "type": "sqlite",
    "sqlite": {
      "database": "/opt/n8n/data/database.sqlite"
    }
  },
  "security": {
    "basicAuth": {
      "active": false
    },
    "jwtAuth": {
      "active": true,
      "jwtHeader": "Authorization"
    }
  },
  "logging": {
    "level": "info",
    "output": "console",
    "file": "/var/log/n8n/n8n.log"
  }
}
