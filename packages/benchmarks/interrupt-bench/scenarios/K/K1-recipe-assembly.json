{
  "id": "K1-recipe-assembly",
  "category": "K",
  "interruptionType": "addition",
  "weight": 2,
  "description": "User assembles a recipe request piece-by-piece across five short messages. The agent must coalesce the full specification (cuisine, dietary, time, servings) into one cohesive recipe reply.",
  "setup": {
    "agentId": "agent-test",
    "rooms": [{ "id": "dm-alice", "kind": "dm", "owner": "alice" }],
    "users": [{ "id": "alice", "role": "OWNER" }],
    "openThreads": [],
    "scheduledTasks": [],
    "memory": []
  },
  "script": [
    {
      "t": 0,
      "channel": "dm-alice",
      "sender": "alice",
      "text": "i want a recipe"
    },
    { "t": 500, "channel": "dm-alice", "sender": "alice", "text": "italian" },
    {
      "t": 1000,
      "channel": "dm-alice",
      "sender": "alice",
      "text": "gluten free"
    },
    {
      "t": 1500,
      "channel": "dm-alice",
      "sender": "alice",
      "text": "under 30 minutes"
    },
    {
      "t": 2000,
      "channel": "dm-alice",
      "sender": "alice",
      "text": "for 4 people"
    }
  ],
  "quiesceAfterMs": 5000,
  "expectedFinalState": {
    "threads": [],
    "scheduledTasks": [],
    "repliesByChannel": {
      "dm-alice": { "count": { "min": 1, "max": 1 }, "mustContain": ["recipe"] }
    }
  },
  "expectedTrace": {
    "stage1Calls": { "min": 1, "max": 2 },
    "plannerCalls": { "min": 0, "max": 2 },
    "boundaryViolations": 0,
    "intent": "RESPOND"
  },
  "responseRubric": {
    "judgePrompt": "Does the final reply propose an Italian, gluten-free recipe for 4 people achievable in under 30 minutes? All four constraints must appear honored.",
    "passRequiredForBonus": true
  }
}
