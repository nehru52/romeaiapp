      "dm-alice": { "count": { "min": 0, "max": 1 } }
    },
    "pendingPrompts": {
      "prompt-deploy-approval-1": { "resolved": true }
    }
  },
  "expectedTrace": {
    "stage1Calls": { "min": 1, "max": 1 },
    "plannerCalls": { "min": 0, "max": 1 },
    "boundaryViolations": 0,
    "intent": "RESPOND"
  },
  "responseRubric": {
    "judgePrompt": "Did the agent recognize Alice's 'yes' in group-team as the answer to the pending deploy approval (originally asked in dm-alice), resolve the prompt, and resume the thread?",
    "passRequiredForBonus": true
  }
