{
  "id": "G1-cross-channel-prompt-resolution",
  "category": "G",
  "interruptionType": "addition",
  "weight": 3,
  "description": "Agent earlier asked the user a yes/no question on dm-alice. User instead answers in a different room (group-team). Agent must resolve the pending prompt by the user's identity, not by channel, and update the right thread.",
  "setup": {
    "agentId": "agent-test",
    "rooms": [
      { "id": "dm-alice", "kind": "dm", "owner": "alice" },
      { "id": "group-team", "kind": "group", "members": ["alice", "carol"] }
    ],
    "users": [
      { "id": "alice", "role": "OWNER" },
      { "id": "carol", "role": "USER" }
    ],
    "openThreads": [
      {
        "id": "thread-deploy-001",
        "owner": "alice",
        "status": "waiting",
        "instruction": "deploy site once approved",
        "roomId": "dm-alice",
        "pendingPromptId": "prompt-deploy-approval-1"
      }
    ],
    "scheduledTasks": [],
    "memory": [],
    "pendingPrompts": [
      {
        "id": "prompt-deploy-approval-1",
        "askedIn": "dm-alice",
        "askedAt": -60000,
        "question": "ready to deploy? yes/no"
      }
    ]
  },
  "script": [
    {
      "t": 0,
      "channel": "group-team",
      "sender": "alice",
      "text": "yes go ahead and deploy"
    }
  ],
  "quiesceAfterMs": 3000,
  "expectedFinalState": {
    "threads": [{ "id": "thread-deploy-001", "status": "active" }],
    "scheduledTasks": [],
    "repliesByChannel": {
