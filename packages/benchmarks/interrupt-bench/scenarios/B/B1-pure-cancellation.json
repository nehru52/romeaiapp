{
  "id": "B1-pure-cancellation",
  "category": "B",
  "interruptionType": "retraction",
  "weight": 3,
  "description": "An active thread is running. The user says 'stop'. The agent must abort the turn, end the thread, and emit a short acknowledgement — NOT route to the planner.",
  "setup": {
    "agentId": "agent-test",
    "rooms": [{ "id": "dm-alice", "kind": "dm", "owner": "alice" }],
    "users": [{ "id": "alice", "role": "OWNER" }],
    "openThreads": [
      {
        "id": "thread-research-001",
        "owner": "alice",
        "status": "active",
        "instruction": "research best EV chargers for home install",
        "roomId": "dm-alice"
      }
    ],
    "scheduledTasks": [],
    "memory": []
  },
  "script": [
    {
      "t": 0,
      "channel": "dm-alice",
      "sender": "alice",
      "text": "actually nvm stop"
    }
  ],
  "quiesceAfterMs": 3000,
  "expectedFinalState": {
    "threads": [{ "id": "thread-research-001", "status": "stopped" }],
    "scheduledTasks": [],
    "repliesByChannel": {
      "dm-alice": { "count": { "min": 1, "max": 1 }, "shortAck": true }
    }
  },
  "expectedTrace": {
    "stage1Calls": { "min": 1, "max": 1 },
    "plannerCalls": { "min": 0, "max": 0 },
    "boundaryViolations": 0,
    "abortFired": true,
    "preemptMode": "ack-and-stop",
    "intent": "RESPOND"
  },
  "responseRubric": {
    "judgePrompt": "Is the agent's reply a brief acknowledgement (e.g., 'ok stopping', 'got it, cancelled') and NOT a continuation of the prior research?",
    "passRequiredForBonus": true
  }
}
