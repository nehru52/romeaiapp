{
  "compilerOptions": {
    "paths": {
      "@elizaos/plugin-whatsapp": ["../plugin-whatsapp/src/index.ts"],
      "@elizaos/plugin-whatsapp/*": ["../plugin-whatsapp/src/*"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node", "bun-types"]
  },
  "include": ["src", "../../packages/agent/src/external-modules.d.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.e2e.test.ts",
    "build.ts"
  ]
}
