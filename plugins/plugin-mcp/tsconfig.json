{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "strictNullChecks": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noImplicitAny": false,
    "paths": {
      "@elizaos/core": ["../../packages/core/src/index.node.ts"],
      "@elizaos/core/*": ["../../packages/core/src/*"],
      "@elizaos/security": ["../../packages/security/src/index.ts"],
      "@elizaos/security/*": ["../../packages/security/src/*"],
      "@elizaos/shared": ["../../packages/shared/src/index.ts"],
      "@elizaos/shared/*": ["../../packages/shared/src/*"],
      "@elizaos/agent": ["../../packages/agent/src/index.ts"],
      "@elizaos/agent/*": ["../../packages/agent/src/*"],
      "@elizaos/plugin-mcp": ["./src/index.ts"],
      "@elizaos/plugin-mcp/*": ["./src/*"],
      "@elizaos/plugin-discord": ["../../plugins/plugin-discord/index.ts"],
      "@elizaos/plugin-discord/*": ["../../plugins/plugin-discord/*"],
      "@elizaos/plugin-imessage": ["../../plugins/plugin-imessage/src/index.ts"],
      "@elizaos/plugin-imessage/*": ["../../plugins/plugin-imessage/src/*"],
      "@elizaos/plugin-elizacloud": ["../../plugins/plugin-elizacloud/src/index.node.ts"],
      "@elizaos/plugin-elizacloud/*": ["../../plugins/plugin-elizacloud/src/*"],
      "@elizaos/plugin-computeruse": ["../../plugins/plugin-computeruse/src/index.ts"],
      "@elizaos/plugin-computeruse/*": ["../../plugins/plugin-computeruse/src/*"],
      "@elizaos/plugin-music": ["../../plugins/plugin-music/src/index.ts"],
      "@elizaos/plugin-music/*": ["../../plugins/plugin-music/src/*"],
      "@elizaos/plugin-whatsapp": ["../../plugins/plugin-whatsapp/src/index.ts"],
      "@elizaos/plugin-whatsapp/*": ["../../plugins/plugin-whatsapp/src/*"],
      "@elizaos/plugin-workflow": ["../../plugins/plugin-workflow/src/index.ts"],
      "@elizaos/plugin-workflow/*": ["../../plugins/plugin-workflow/src/*"],
      "@elizaos/plugin-streaming": ["../../plugins/plugin-streaming/src/index.ts"],
      "@elizaos/plugin-streaming/*": ["../../plugins/plugin-streaming/src/*"],
      "@elizaos/plugin-sql": ["../../plugins/plugin-sql/src/index.node.ts"],
      "@elizaos/plugin-sql/*": ["../../plugins/plugin-sql/src/*"],
      "@elizaos/plugin-browser": ["../../plugins/plugin-browser/src/index.ts"],
      "@elizaos/plugin-browser/*": ["../../plugins/plugin-browser/src/*"],
      "@elizaos/plugin-signal": ["../../plugins/plugin-signal/src/index.ts"],
      "@elizaos/plugin-signal/*": ["../../plugins/plugin-signal/src/*"],
      "@elizaos/plugin-google": ["../../plugins/plugin-google/src/index.ts"],
      "@elizaos/plugin-google/*": ["../../plugins/plugin-google/src/*"],
      "@elizaos/plugin-telegram": ["../../plugins/plugin-telegram/src/index.ts"],
      "@elizaos/plugin-telegram/*": ["../../plugins/plugin-telegram/src/*"],
      "@elizaos/plugin-discord-local": ["../../plugins/plugin-discord-local/src/index.ts"],
      "@elizaos/plugin-discord-local/*": ["../../plugins/plugin-discord-local/src/*"],
      "@elizaos/plugin-local-inference": ["../../plugins/plugin-local-inference/src/index.ts"],
      "@elizaos/plugin-local-inference/*": ["../../plugins/plugin-local-inference/src/*"],
      "@elizaos/plugin-task-coordinator": ["../../plugins/plugin-task-coordinator/src/index.ts"],
      "@elizaos/plugin-task-coordinator/*": ["../../plugins/plugin-task-coordinator/src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "__tests__/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "build.ts",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.e2e.test.ts"
  ]
}
