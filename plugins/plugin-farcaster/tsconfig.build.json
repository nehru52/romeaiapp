{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@elizaos/core": ["../../../packages/core/dist"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "__tests__", "**/*.test.ts", "build.ts", "vitest.config.ts"]
}
