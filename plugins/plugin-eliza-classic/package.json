{
  "name": "@elizaos/plugin-eliza-classic",
  "version": "2.0.3-beta.0",
  "type": "module",
  "description": "Deterministic ELIZA-style pattern matching (browser + Node); ships compiled ESM in dist/.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.browser.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "types": "./dist/index.browser.d.ts",
        "import": "./dist/index.browser.js",
        "default": "./dist/index.browser.js"
      },
      "node": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run scripts/build.mjs",
    "dev": "tsup --config tsup.config.ts --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "echo \"Lint skipped\"",
    "lint:check": "bun run lint",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos/eliza.git",
    "directory": "plugins/plugin-eliza-classic"
  }
}
