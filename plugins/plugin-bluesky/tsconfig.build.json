{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist/node",
		"rootDir": ".",
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"noEmit": false
	},
	"include": ["*.ts", "managers/**/*.ts", "services/**/*.ts", "types/**/*.ts", "utils/**/*.ts"],
	"exclude": ["node_modules", "dist", "build.ts", "vitest.config.ts", "__tests__", "**/*.test.ts"]
}
