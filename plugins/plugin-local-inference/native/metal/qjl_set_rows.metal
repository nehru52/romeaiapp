static inline float qjl_projection_value(uint i, uint j) {
    return as_type<float>(QJL_DEFAULT_PROJECTION_BITS[i * QJL_PROJECTION_DIM + j]);
}

static inline ushort qjl_fp32_to_bf16(float x) {
    uint u = as_type<uint>(x);
    if ((u & 0x7f800000u) == 0x7f800000u && (u & 0x007fffffu) != 0u) {
        return ushort((u >> 16) | 0x40u);
    }
    uint lsb = (u >> 16) & 1u;
    u += 0x7fffu + lsb;
    return ushort(u >> 16);
}

template<typename TI>
kernel void kernel_set_rows_qjl1_256_t(
        constant ggml_metal_kargs_set_rows & args [[buffer(0)]],
        device const void * src0                 [[buffer(1)]],
        device const void * src1                 [[buffer(2)]],
        device       void * dst                  [[buffer(3)]],
        uint3               tgpig                [[threadgroup_position_in_grid]],
        uint                tid                  [[thread_index_in_threadgroup]]) {
    const int i03 = int(tgpig.z);
    const int i02 = int(tgpig.y);
    const int i01 = int(tgpig.x);
    if (i01 >= args.ne01 || tid >= 32u) {
        return;
    }

    const int i12 = i03 % args.ne12;
    const int i11 = i02 % args.ne11;
    const TI  i1  = ((device const TI *)((device const char *)src1 + i01 * args.nb10 + i11 * args.nb11 + i12 * args.nb12))[0];

    device block_qjl1_256 * dst_row = (device block_qjl1_256 *)((device char *)dst + ulong(i1) * args.nb1 + ulong(i02) * args.nb2 + ulong(i03) * args.nb3);
    device const float * src_row = (device const float *)((device const char *)src0 + ulong(i01) * args.nb01 + ulong(i02) * args.nb02 + ulong(i03) * args.nb03);

    threadgroup float key[QJL_HEAD_DIM];

    for (int block = 0; block < args.nk0; ++block) {
        for (uint i = tid; i < QJL_HEAD_DIM; i += 32u) {
            key[i] = src_row[block * QJL_HEAD_DIM + int(i)];
        }
        threadgroup_barrier(mem_flags::mem_threadgroup);

        const uint byte_i = tid;
        uchar packed = 0u;
        for (uint bit = 0; bit < 8u; ++bit) {
            const uint j = byte_i * 8u + bit;
            float acc = 0.0f;
            for (uint i = 0; i < QJL_HEAD_DIM; ++i) {
                acc = fma(key[i], qjl_projection_value(i, j), acc);
            }
            if (acc > 0.0f) {
                packed |= uchar(1u << bit);
            }
        }
        dst_row[block].signs[byte_i] = packed;

        float norm_sq = 0.0f;
        for (uint i = tid; i < QJL_HEAD_DIM; i += 32u) {
            const float v = key[i];
            norm_sq = fma(v, v, norm_sq);
        }
        const float norm_sum = simd_sum(norm_sq);
        if (tid == 0u) {
            dst_row[block].d = qjl_fp32_to_bf16(sqrt(norm_sum));
        }
        threadgroup_barrier(mem_flags::mem_threadgroup);
    }
}

