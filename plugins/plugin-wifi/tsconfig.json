{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": false,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types",
      "../../../node_modules",
      "../../../node_modules/.bun/node_modules"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "drizzle-orm": ["../plugin-sql/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../plugin-sql/node_modules/drizzle-orm/*"],
      "@elizaos/agent": ["../../packages/agent/src/index.ts"],
      "@elizaos/plugin-app-manager": [
        "../../plugins/plugin-app-manager/src/index.ts"
      ],
      "@elizaos/app-core": ["../../packages/app-core/src/index.ts"],
      "@elizaos/app-core/*": ["../../packages/app-core/src/*"],
      "@elizaos/core": ["../../packages/core/src/index.node.ts"],
      "@elizaos/ui": ["../../packages/ui/dist/index.d.ts"],
      "@elizaos/ui/*": ["../../packages/ui/dist/*"],
      "@elizaos/shared": ["../../packages/shared/src/index.ts"],
      "@elizaos/shared/*": ["../../packages/shared/src/*"],
      "@elizaos/capacitor-wifi": [
        "../../plugins/plugin-native-wifi/src/index.ts"
      ],
      "@elizaos/capacitor-system": [
        "../../plugins/plugin-native-system/src/index.ts"
      ],
      "@elizaos/capacitor-bun-runtime": [
        "../../plugins/plugin-native-bun-runtime/src/index.ts"
      ],
      "@elizaos/plugin-discord-local": [
        "../../plugins/plugin-discord-local/src/index.ts"
      ],
      "@elizaos/plugin-discord-local/*": [
        "../../plugins/plugin-discord-local/src/*"
      ],
      "@elizaos/plugin-wallet-ui": [
        "../../plugins/plugin-wallet-ui/src/index.ts"
      ],
      "@elizaos/plugin-wallet-ui/*": ["../../plugins/plugin-wallet-ui/src/*"],
      "@elizaos/plugin-task-coordinator": [
        "../../plugins/plugin-task-coordinator/src/index.ts"
      ],
      "@elizaos/plugin-task-coordinator/*": [
        "../../plugins/plugin-task-coordinator/src/*"
      ],
      "@elizaos/plugin-elizacloud": [
        "../../plugins/plugin-elizacloud/src/index.node.ts"
      ],
      "@elizaos/plugin-elizacloud/*": ["../../plugins/plugin-elizacloud/src/*"],
      "@elizaos/plugin-discord": ["../../plugins/plugin-discord/index.ts"],
      "@elizaos/plugin-discord/*": ["../../plugins/plugin-discord/*"],
      "@elizaos/plugin-browser": ["../../plugins/plugin-browser/src/index.ts"],
      "@elizaos/plugin-computeruse": [
        "../../plugins/plugin-computeruse/src/index.ts"
      ],
      "@elizaos/plugin-signal": ["../../plugins/plugin-signal/src/index.ts"],
      "@elizaos/plugin-whatsapp": [
        "../../plugins/plugin-whatsapp/src/index.ts"
      ],
      "react": ["../../packages/app-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "../../packages/app-core/node_modules/@types/react-dom/index.d.ts"
      ],
      "@elizaos/plugin-mcp": ["../../plugins/plugin-mcp/src/index.ts"],
      "@elizaos/plugin-mcp/*": ["../../plugins/plugin-mcp/src/*"],
      "@elizaos/plugin-workflow": [
        "../../plugins/plugin-workflow/src/index.ts"
      ],
      "@elizaos/plugin-workflow/*": ["../../plugins/plugin-workflow/src/*"],
      "@elizaos/plugin-streaming": [
        "../../plugins/plugin-streaming/src/index.ts"
      ],
      "@elizaos/plugin-streaming/*": ["../../plugins/plugin-streaming/src/*"],
      "@elizaos/plugin-music": ["../../plugins/plugin-music/src/index.ts"],
      "@elizaos/plugin-music/*": ["../../plugins/plugin-music/src/*"],
      "@elizaos/plugin-sql": ["../../plugins/plugin-sql/src/index.node.ts"],
      "@elizaos/plugin-sql/*": ["../../plugins/plugin-sql/src/*"],
      "@elizaos/*": ["../../node_modules/@elizaos/*"],
      "lucide-react": ["../plugin-companion/node_modules/lucide-react"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../../packages/agent/src/external-modules.d.ts",
    "../../packages/app-core/src/ambient-modules.d.ts"
  ],
  "exclude": ["src/**/*.stories.ts", "src/**/*.stories.tsx"]
}
