{
  "name": "@elizaos/plugin-mysticism",
  "description": "Mystical divination engines for ElizaOS — Tarot, I Ching, and Astrology readings",
  "version": "2.0.3-beta.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageType": "plugin",
  "platform": "node",
  "license": "MIT",
  "author": "ElizaOS Contributors",
  "keywords": [
    "plugin",
    "elizaos",
    "mysticism",
    "tarot",
    "iching",
    "astrology",
    "divination"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "eliza-source": {
        "types": "./src/*.ts",
        "import": "./src/*.ts",
        "default": "./src/*.ts"
      },
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --hot build.ts",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit --noCheck",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "clean": "rm -rf dist .turbo",
    "format": "bunx @biomejs/biome format --write ."
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginParameters": {
      "MYSTICISM_PRICE_TAROT": {
        "type": "number",
        "description": "Price in SOL for this reading type",
        "required": false,
        "sensitive": false
      },
      "MYSTICISM_PRICE_ICHING": {
        "type": "number",
        "description": "Price in SOL for this reading type",
        "required": false,
        "sensitive": false
      },
      "MYSTICISM_PRICE_ASTROLOGY": {
        "type": "number",
        "description": "Price in SOL for this reading type",
        "required": false,
        "sensitive": false
      }
    }
  }
}
